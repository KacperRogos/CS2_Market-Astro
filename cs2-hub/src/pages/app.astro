function getItemCategory(name) {
  const n = name.toLowerCase();
  if (/knife|karambit|butterfly|bayonet|stiletto|talon|ursus|navaja|shadow|flip|gut|huntsman|falchion|bowie|m9|paracord|survival|nomad|skeleton|classic knife|kukri/.test(n)) return 'knife';
  if (/gloves|wraps|hand wraps|moto gloves|specialist gloves|sport gloves|bloodhound|hydra/.test(n)) return 'gloves';
  if (/\bcase\b|weapon case|operation|clutch case|fracture|snakebite|riptide|dreams|nightmares|revolution|recoil|prisma|horizon|spectrum|danger zone|hydra case|phoenix|falchion case|chroma|bravo|esports|huntsman case|breakout|kilowatt|gallery|musica/.test(n)) return 'case';
  if (/capsule|autograph|legends|challengers|contenders/.test(n)) return 'capsule';
  if (/sticker/.test(n)) return 'sticker';
  if (/ak-47|m4a4|m4a1|awp|sg 553|aug|famas|galil|scar-20|g3sg1|mac-10|mp5|mp7|mp9|pp-bizon|p90|ump-45|xm1014|nova|mag-7|sawed-off|negev|m249|p2000|usp-s|glock|p250|five-seven|cz75|tec-9|desert eagle|r8|dual berettas/.test(n)) return 'weapon';
  return 'other';
}

function setSort(sort) {
  currentSort = sort; renderItems();
}

function getSortedItems() {
  let filtered = currentCategory === 'all' ? [...items] : items.filter(i => getItemCategory(i.name) === currentCategory);
  switch (currentSort) {
    case 'price_desc': return filtered.sort((a, b) => (b.price || 0) - (a.price || 0));
    case 'price_asc':  return filtered.sort((a, b) => (a.price || 0) - (b.price || 0));
    case 'qty_desc':   return filtered.sort((a, b) => b.qty - a.qty);
    case 'qty_asc':    return filtered.sort((a, b) => a.qty - b.qty);
    case 'name':       return filtered.sort((a, b) => a.name.localeCompare(b.name));
    default:           return filtered;
  }
}

