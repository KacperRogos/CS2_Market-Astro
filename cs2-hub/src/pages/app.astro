});

// ─── CORE ─────────────────────────────────────────────────────
let currentSort = 'default';
let currentCategory = 'all';
const STEAM_API_KEY = 'BD66D8B47D16AFE61244897621C4CE52';
let items = JSON.parse(localStorage.getItem('cs2_items') || '[]');
let suggestTimeout = null;
const priceCache = new Map();
const CACHE_TTL = 5 * 60 * 1000;
const STEAM_USD_PLN = 3.6979;

function showError(msg) {
  const el = document.getElementById('errorNotice');
  el.textContent = msg; el.classList.add('show');
  setTimeout(() => el.classList.remove('show'), 5000);
}

function escapeHtml(str) {
  return String(str||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;').replace(/'/g,'&#39;');
}

async function steamFetch(steamUrl) {
  const resp = await fetch(`${SUPABASE_FUNCTIONS_URL}/steam-price`, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json', 'apikey': SUPABASE_KEY, 'Authorization': `Bearer ${SUPABASE_KEY}` },
    body: JSON.stringify({ steamUrl })
  });
  if (!resp.ok) throw new Error(`Edge Function error: ${resp.status}`);
  return resp.json();
}

async function fetchPrice(marketHashName, isRetry = false) {
  const cached = priceCache.get(marketHashName);
  if (cached && Date.now() - cached.ts < CACHE_TTL) return cached.result;
  try {
    // Najpierw sprawdź naszą własną tabelę cache — szybkie, niezawodne, zero zależności od Steam.
    let iconUrl = '';
    try {
      const { data: cachedIcon } = await _sb
        .from('item_icons')
        .select('icon_url')
        .eq('market_hash_name', marketHashName)
        .maybeSingle();
      if (cachedIcon?.icon_url) iconUrl = cachedIcon.icon_url;
    } catch (e) { /* brak w cache — spróbujemy Steam poniżej */ }

    const [priceResp, searchData] = await Promise.all([
      fetch(`${SUPABASE_FUNCTIONS_URL}/steam-price`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'apikey': SUPABASE_KEY, 'Authorization': `Bearer ${SUPABASE_KEY}` },
        body: JSON.stringify({ itemName: marketHashName })
      }),
      // Ten sam endpoint co wyszukiwarka skinów (market/search/render) — jedno zapytanie
      // zwraca od razu icon_url, dużo bardziej niezawodne niż osobny render/ per przedmiot,
      // który był głównym źródłem brakujących obrazków przy ręcznym dodawaniu / demo.
      iconUrl ? Promise.resolve(null) : steamFetch(`https://steamcommunity.com/market/search/render/?appid=730&norender=1&search_descriptions=0&query=${encodeURIComponent(marketHashName)}&start=0&count=5&currency=6`).catch(() => null)
    ]);
    const data = await priceResp.json();

    // Steam czasem odpowiada rate-limitem albo stroną błędu (nie prawdziwym "brak ofert").
    // Zamiast od razu poddawać się, spróbuj raz jeszcze po chwili — to naśladuje to,
    // co i tak robisz ręcznie odświeżając stronę kilka razy.
    if (!data.success && !isRetry) {
      await new Promise(r => setTimeout(r, 1500 + Math.random() * 1000));
      return fetchPrice(marketHashName, true);
    }

    if (!iconUrl) {
      const results = searchData?.results;
      if (Array.isArray(results) && results.length) {
        const exact = results.find(r => r.name === marketHashName) || results[0];
        iconUrl = exact?.asset_description?.icon_url || '';
      }
    }
    let result = null;
    if (data.success && data.lowest_price) {
      const raw = data.lowest_price;
      const num = parseFloat(raw.replace(/[^\d,]/g, '').replace(',', '.'));
      if (!isNaN(num) && num > 0) result = { price: num, raw: raw.includes('zł') ? raw : raw + ' zł', volume: data.volume || 0, iconUrl };
    }
    if (!result && iconUrl) result = { price: null, raw: null, volume: 0, iconUrl };
    priceCache.set(marketHashName, { result, ts: Date.now() });
    return result;
  } catch(e) { return null; }
}

const WEAR_TRANSLATIONS = { 'prosto z fabryki':'Factory New','fn':'Factory New','lekkie zuzycie':'Minimal Wear','lekkie zużycie':'Minimal Wear','mw':'Minimal Wear','po testach bojowych':'Field-Tested','po testach':'Field-Tested','ft':'Field-Tested','mocne zuzycie':'Well-Worn','mocne zużycie':'Well-Worn','ww':'Well-Worn','po ciezkich walkach':'Battle-Scarred','po ciężkich walkach':'Battle-Scarred','bs':'Battle-Scarred' };

function insertWear(wearEn) {
  const input = document.getElementById('itemNameInput');
  const withoutWear = input.value.replace(/\s*\([^)]*\)\s*$/, '').trim();
  input.value = withoutWear + (withoutWear ? ' (' + wearEn + ')' : '(' + wearEn + ')');
  input.focus(); onItemInput(input);
}

function translateWearInInput(val) {
  return val.replace(/\(([^)]+)\)/g, (match, inner) => {
    const key = inner.trim().toLowerCase();
    return WEAR_TRANSLATIONS[key] ? '(' + WEAR_TRANSLATIONS[key] + ')' : match;
  });
}

async function onItemInput(input) {
  clearTimeout(suggestTimeout);
  const val = input.value.trim();
  if (val.length < 3) { document.getElementById('suggestions').style.display = 'none'; return; }
  suggestTimeout = setTimeout(async () => {
    try {
      const url = `https://steamcommunity.com/market/search/render/?appid=730&norender=1&search_descriptions=0&query=${encodeURIComponent(val)}&start=0&count=6&currency=6`;
      const data = await steamFetch(url);
      if (data.results && data.results.length > 0) showSuggestions(data.results);
      else document.getElementById('suggestions').style.display = 'none';
    } catch(e) { document.getElementById('suggestions').style.display = 'none'; }
  }, 400);
}

const suggestionIconCache = new Map();
function showSuggestions(results) {
  const box = document.getElementById('suggestions');
  box.innerHTML = results.map(r => {
    const iconUrl = r.asset_description?.icon_url || '';
    const img = iconUrl ? `https://community.cloudflare.steamstatic.com/economy/image/${iconUrl}/62fx46f` : '';
    if (iconUrl) suggestionIconCache.set(r.name, iconUrl);
    return `<div class="suggestion-item" onclick="selectSuggestion('${escapeHtml(r.name)}')">
      ${img ? `<img class="suggestion-img" src="${img}" onerror="this.style.display='none'">` : ''}
      <div class="suggestion-info"><div class="suggestion-name">${escapeHtml(r.name)}</div><div class="suggestion-price">${r.sell_price_text || ''}</div></div>
    </div>`;
  }).join('');
  box.style.display = 'block';
}

function selectSuggestion(name) {
  document.getElementById('itemNameInput').value = name;
  document.getElementById('suggestions').style.display = 'none';
  document.getElementById('itemNameInput').focus();
}

document.addEventListener('click', e => { if (!e.target.closest('.input-group')) document.getElementById('suggestions').style.display = 'none'; });

let addItemInProgress = false;
async function addItem() {
  if (addItemInProgress) return; addItemInProgress = true;
  let name = document.getElementById('itemNameInput').value.trim();
  name = translateWearInInput(name);
  const qty = parseInt(document.getElementById('itemQtyInput').value) || 1;
  if (!name) { showError('Wpisz nazwę przedmiotu!'); addItemInProgress = false; return; }
  const exists = items.find(i => i.name === name);
  if (exists) { exists.qty += qty; saveItems(); renderItems(); addItemInProgress = false; return; }
  const item = { id: Date.now(), name, qty, price: null, priceRaw: null, iconUrl: null, loading: true };
  items.push(item); saveItems(); renderItems();
  document.getElementById('itemNameInput').value = '';
  document.getElementById('itemQtyInput').value = '1';
  const cachedIcon = suggestionIconCache.get(name);
  if (cachedIcon) { item.iconUrl = cachedIcon; renderItems(); }
  const result = await fetchPrice(name);
  item.loading = false;
  if (result) { if (result.price !== null) { item.price = result.price; item.priceRaw = result.raw; item.volume = result.volume; } if (result.iconUrl) item.iconUrl = result.iconUrl; }
  saveItems(); renderItems(); addItemInProgress = false;
}

function updateItemPrice(item, result) {
  if (!result || !result.price) return;
  const today = new Date().toDateString();
  const yesterday = new Date(Date.now() - 86400000).toDateString();
  if (!item.snapshotPrice || !item.snapshotDate) { item.snapshotPrice = result.price; item.snapshotDate = today; }
  else if (item.snapshotDate !== today && item.snapshotDate !== yesterday) { item.snapshotPrice = item.price || result.price; item.snapshotDate = yesterday; }
  item.price = result.price; item.priceRaw = result.raw; item.lastUpdated = Date.now();
}

function increaseQty(id) { const item = items.find(i => i.id === id); if (!item) return; item.qty++; saveItems(); renderItems(); }
function decreaseQty(id) { const item = items.find(i => i.id === id); if (!item) return; if (item.qty > 1) item.qty--; else items = items.filter(i => i.id !== id); saveItems(); renderItems(); }
function setQty(id, val) { const item = items.find(i => i.id === id); if (!item) return; const p = parseInt(val, 10); if (isNaN(p) || p < 1) items = items.filter(i => i.id !== id); else item.qty = p; saveItems(); renderItems(); }
function getPriceChange(item) { if (!item.snapshotPrice || !item.price) return null; const pct = ((item.price - item.snapshotPrice) / item.snapshotPrice) * 100; if (Math.abs(pct) < 0.01) return null; return pct; }

let refreshStopped = false;
let refreshGeneration = 0;

function stopRefresh() {
  refreshStopped = true; refreshGeneration++;
  document.getElementById('stopRefreshBtn').style.display = 'none';
  const btn = document.getElementById('refreshAllBtn');
  btn.innerHTML = `<span id="refreshAllIcon">⟳</span> Odśwież wszystkie`; btn.disabled = false; btn.classList.remove('spinning');
  items.forEach(i => { i.loading = false; }); saveItems(); renderItems();
}

async function refreshAllItems() {
  if (items.length === 0) return;
  refreshStopped = false;
  const myGen = ++refreshGeneration;
  const btn = document.getElementById('refreshAllBtn'), stopBtn = document.getElementById('stopRefreshBtn');
  if (btn) { btn.disabled = true; btn.classList.add('spinning'); }
  if (stopBtn) stopBtn.style.display = 'block';
  const BATCH = 2; let done = 0;
  const updateBtn = () => { if (btn) btn.innerHTML = `<span id="refreshAllIcon" style="display:inline-block;animation:spin 0.8s linear infinite">⟳</span> ${done}/${items.length}`; };
  for (let i = 0; i < items.length; i += BATCH) {
    if (refreshStopped || myGen !== refreshGeneration) break;
    const batch = items.slice(i, i + BATCH);
    batch.forEach(item => { item.loading = true; }); renderItems();
    await Promise.all(batch.map(async (item) => {
      if (refreshStopped || myGen !== refreshGeneration) { item.loading = false; return; }
      const result = await fetchPrice(item.name);
      if (refreshStopped || myGen !== refreshGeneration) { item.loading = false; return; }
      item.loading = false; updateItemPrice(item, result); if (result && result.iconUrl) item.iconUrl = result.iconUrl; done++; updateBtn();
    }));
    if (refreshStopped || myGen !== refreshGeneration) break;
    saveItems(); renderItems();
    if (i + BATCH < items.length && !refreshStopped) await new Promise(r => setTimeout(r, 900));
  }
  if (myGen !== refreshGeneration) return;
  if (btn) { btn.disabled = false; btn.classList.remove('spinning'); btn.innerHTML = refreshStopped ? `<span id="refreshAllIcon">⟳</span> Odśwież` : `<span id="refreshAllIcon">⟳</span> Odświeżono!`; if (!refreshStopped) setTimeout(() => { btn.innerHTML = `<span id="refreshAllIcon">⟳</span> Odśwież`; }, 2000); }
  if (stopBtn) stopBtn.style.display = 'none';
  saveItems(); renderItems();
  if (!refreshStopped) autoSnapshot();
}

async function refreshItem(id) {
  const item = items.find(i => i.id === id); if (!item) return;
  item.loading = true; renderItems();
  const result = await fetchPrice(item.name);
  item.loading = false; updateItemPrice(item, result);
  if (result) { if (result.volume) item.volume = result.volume; if (result.iconUrl) item.iconUrl = result.iconUrl; }
  saveItems(); renderItems();
  setTimeout(() => { const card = document.getElementById('card-' + id); if (card) { const el = card.querySelector('.item-price-total'); if (el) { el.classList.remove('price-flash'); void el.offsetWidth; el.classList.add('price-flash'); } } }, 50);
}

function removeItem(id) { items = items.filter(i => i.id !== id); saveItems(); renderItems(); }
function saveItems() { localStorage.setItem('cs2_items', JSON.stringify(items)); saveToSupabase(); }

function getWearTag(name) { for (const w of ['Factory New','Minimal Wear','Field-Tested','Well-Worn','Battle-Scarred']) { if (name.includes(w)) return w; } return null; }

function buildCardHtml(item, idx) {
  const wear = getWearTag(item.name);
  const weaponName = item.name.includes('|') ? item.name.split('|')[0].trim() : item.name;
  const skinName = item.name.includes('|') ? item.name.split('|')[1].replace(/\(.*\)/, '').trim() : '';
  const imgSrc = item.iconUrl ? (item.iconUrl.startsWith('http') ? item.iconUrl : `https://community.cloudflare.steamstatic.com/economy/image/${item.iconUrl}/360fx230f`) : '';
  let changeBadge = '';
  const pct = getPriceChange(item);
  if (pct !== null) {
    const absPct = Math.abs(pct).toFixed(1);
    if (pct >= 15) changeBadge = `<div class="price-change up"><span style="color:#39ff14">▲</span> +${absPct}%</div>`;
    else if (pct <= -10) changeBadge = `<div class="price-change down"><span style="color:#ff4444">▼</span> −${absPct}%</div>`;
    else if (pct > 0) changeBadge = `<div class="price-change neutral"><span style="color:#39ff14">▲</span> +${absPct}%</div>`;
    else changeBadge = `<div class="price-change neutral"><span style="color:#ff4444">▼</span> −${absPct}%</div>`;
  }
  const delay = idx < 8 ? idx * 55 : 0;
  return `<div class="item-card" id="card-${item.id}" style="animation-delay:${delay}ms">
    <div class="item-refresh-overlay" style="display:none"><span class="item-refresh-spinner">⟳</span><span class="item-refresh-label">Odświeżanie</span></div>
    <div class="item-img-banner">
      ${imgSrc ? `<img src="${imgSrc}" onerror="this.style.display='none'" alt="${escapeHtml(item.name)}">` : '<div class="img-placeholder-big"></div>'}
      ${changeBadge ? `<div class="change-badge-wrap">${changeBadge}</div>` : ''}
    </div>
    <div class="item-body">
      <div class="item-weapon">${escapeHtml(weaponName)}</div>
      <div class="item-skin">${escapeHtml(skinName)}</div>
      <div style="display:flex;align-items:center;gap:8px;margin-top:6px">
        ${wear ? `<div class="item-wear">${wear}</div>` : ''}
        <div class="qty-control">
          <button onclick="decreaseQty(${item.id})">−</button>
          <input type="number" class="qty-input" value="${item.qty}" min="1" max="9999" onchange="setQty(${item.id},this.value)" onclick="this.select()" style="width:46px;text-align:center;background:#0f172a;border:1px solid rgba(255,255,255,0.1);color:#00ffa6;border-radius:6px;padding:2px 4px;font-size:14px;font-weight:600;outline:none">
          <button onclick="increaseQty(${item.id})">+</button>
        </div>
      </div>
    </div>
    <div class="item-price-row">
      <div class="item-price-single">${item.price !== null && item.price > 0 ? `${item.priceRaw || (item.price.toFixed(2).replace('.',',') + ' zł')} / szt.` : '<span style="color:#ff6b6b;font-size:12px">Nie znaleziono</span>'}</div>
      <div class="item-price-total">${item.price !== null && item.price > 0 ? (item.price * item.qty).toFixed(2).replace('.', ',') + ' zł' : ''}</div>
    </div>
    ${pct !== null && item.snapshotPrice ? `<div class="price-history-row"><span class="price-history-label">Wczoraj:</span><span class="price-history-val">${item.snapshotPrice.toFixed(2).replace('.', ',')} zł</span></div>` : ''}
    <div class="item-actions">
      <button class="refresh-btn" onclick="refreshItem(${item.id})">⟳ Odśwież</button>
      <button class="btn btn-danger" onclick="removeItem(${item.id})">X</button>
    </div>
  </div>`;
}

function updateCardOverlay(id, loading) { const card = document.getElementById('card-' + id); if (!card) return; const overlay = card.querySelector('.item-refresh-overlay'); if (!overlay) return; overlay.style.display = loading ? 'flex' : 'none'; }

function renderItems() {
  const grid = document.getElementById('itemsGrid');
  if (items.length === 0) { grid.innerHTML = `<div class="empty-state"><div class="empty-icon"></div><div class="empty-title">Brak przedmiotów</div><div class="empty-sub">Dodaj swoje skiny CS2 powyżej</div></div>`; updateStats(); return; }
  const sorted = getSortedItems();
  const existingIds = [...grid.querySelectorAll('.item-card')].map(el => el.id);
  const newIds = sorted.map(i => 'card-' + i.id);
  const structureMatches = existingIds.length === newIds.length && existingIds.every((id, i) => id === newIds[i]);
  if (!structureMatches) grid.innerHTML = sorted.map((item, idx) => buildCardHtml(item, idx)).join('');
  sorted.forEach(item => {
    updateCardOverlay(item.id, item.loading);
    const card = document.getElementById('card-' + item.id); if (!card) return;
    const imgEl = card.querySelector('.item-img-banner img');
    if (item.iconUrl && !item.loading) {
      const imgSrc = item.iconUrl.startsWith('http') ? item.iconUrl : `https://community.cloudflare.steamstatic.com/economy/image/${item.iconUrl}/360fx230f`;
      if (!imgEl) { const banner = card.querySelector('.item-img-banner'); if (banner) { const ph = banner.querySelector('.img-placeholder-big'); if (ph) { const img = document.createElement('img'); img.src = imgSrc; img.alt = item.name; img.onerror = function(){this.style.display='none';}; ph.replaceWith(img); } } }
      else if (!imgEl.src.includes(item.iconUrl.slice(0, 20))) imgEl.src = imgSrc;
    }
    const singleEl = card.querySelector('.item-price-single');
    if (singleEl) singleEl.innerHTML = item.loading ? '<span class="item-price-loading">ładowanie...</span>' : item.price !== null && item.price > 0 ? `${item.priceRaw || (item.price.toFixed(2).replace('.',',') + ' zł')} / szt.` : '<span style="color:#ff6b6b;font-size:12px">Nie znaleziono</span>';
    const totalEl = card.querySelector('.item-price-total');
    if (totalEl && !item.loading) totalEl.textContent = item.price !== null && item.price > 0 ? (item.price * item.qty).toFixed(2).replace('.', ',') + ' zł' : '';
  });
  updateStats();
}

function updateStats() {
  const total = items.reduce((s, i) => s + (i.price || 0) * i.qty, 0);
  document.getElementById('totalDisplay').textContent = total > 0 ? total.toFixed(2).replace('.', ',') + ' zł' : '0,00 zł';
  document.getElementById('statItems').textContent = items.length;
  document.getElementById('statQty').textContent = items.reduce((s, i) => s + i.qty, 0);
  const top = items.filter(i => i.price !== null && i.price > 0).sort((a, b) => b.price - a.price)[0];
  document.getElementById('statTop').textContent = top ? (top.name.split('|')[1]?.trim() || top.name.split(' ')[0]) : '—';
  const changeEl = document.getElementById('totalChangeDisplay');
  const itemsWithSnapshot = items.filter(i => i.snapshotPrice && i.price && i.qty);
  if (itemsWithSnapshot.length > 0) {
    const totalNow = itemsWithSnapshot.reduce((s, i) => s + i.price * i.qty, 0);
    const totalYesterday = itemsWithSnapshot.reduce((s, i) => s + i.snapshotPrice * i.qty, 0);
    const diff = totalNow - totalYesterday;
    const pct = totalYesterday > 0 ? (diff / totalYesterday) * 100 : 0;
    if (Math.abs(diff) >= 0.01) {
      const sign = diff >= 0 ? '+' : '−'; const arrow = diff >= 0 ? '▲' : '▼';
      const color = diff >= 0 ? '#39ff14' : '#ff4444'; const bg = diff >= 0 ? 'rgba(57,255,20,0.1)' : 'rgba(255,68,68,0.1)'; const border = diff >= 0 ? 'rgba(57,255,20,0.3)' : 'rgba(255,68,68,0.3)';
      changeEl.style.display = 'inline-block'; changeEl.style.color = color; changeEl.style.background = bg; changeEl.style.border = `1px solid ${border}`;
      changeEl.textContent = `${arrow} ${sign}${Math.abs(diff).toFixed(2).replace('.', ',')} zł (${sign}${Math.abs(pct).toFixed(2)}%)`;
    } else changeEl.style.display = 'none';
  } else changeEl.style.display = 'none';
}

function toggleAddForm() {
  const wrap = document.getElementById('addFormWrap'), btn = document.getElementById('addToggleBtn');
  const open = wrap.style.display === 'none' || wrap.style.display === '';
  wrap.style.display = open ? 'block' : 'none'; btn.textContent = open ? '✕ Zamknij' : '+ Dodaj skin';
