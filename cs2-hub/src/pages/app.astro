const SUPABASE_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InNhY3hrbHBqdGVxc2Jldm93cm10Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzQzNDkxNzAsImV4cCI6MjA4OTkyNTE3MH0.AGcM2iG_xWgj5KgEYWYCaT-SeBBmA1wesuw9n7MwM5s';
---
<!doctype html>
<html lang="pl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>CS2 Market – Portfel skinów</title>
  <meta name="description" content="Zarządzaj swoim portfelem skinów CS2. Import ze Steam, historia wartości, AI doradca.">
  <meta name="robots" content="noindex">
  <link rel="icon" type="image/png" href="/favicon.png">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@400;500;600;700&family=Orbitron:wght@400;700;900&family=Share+Tech+Mono&display=swap">
  <link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@400;500;600;700&family=Orbitron:wght@400;700;900&family=Share+Tech+Mono&display=swap" rel="stylesheet" media="print" onload="this.media='all'">
  <noscript>
    <link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@400;500;600;700&family=Orbitron:wght@400;700;900&family=Share+Tech+Mono&display=swap" rel="stylesheet">
  </noscript>
</head>
<body>

<script src="https://unpkg.com/@supabase/supabase-js@2" is:inline></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js" is:inline></script>

<!-- AUTH SCREEN -->
<div id="authScreen" style="position:fixed;inset:0;background:var(--bg);z-index:1000;display:flex;align-items:center;justify-content:center;padding:20px">
  <div class="auth-box">
    <div class="auth-logo">
      <h1>CS2 <span>MARKET</span></h1>
      <p>Tracker skinów Steam</p>
    </div>
    <div class="auth-tabs">
      <button class="auth-tab active" id="loginTab" onclick="switchAuthTab('login')">Logowanie</button>
      <button class="auth-tab" id="registerTab" onclick="switchAuthTab('register')">Rejestracja</button>
    </div>
    <div id="loginForm">
      <div class="auth-field">
        <label>Login lub email</label>
        <input type="text" id="loginUsername" placeholder="Nazwa użytkownika lub email" autocomplete="username">
      </div>
      <div class="auth-field">
        <label>Hasło</label>
        <input type="password" id="loginPassword" placeholder="Twoje hasło" autocomplete="current-password" onkeydown="if(event.key==='Enter') doLogin()">
      </div>
      <button class="auth-btn" onclick="doLogin()" id="loginBtn">ZALOGUJ</button>
    </div>
    <div id="registerForm" style="display:none">
      <div class="auth-field">
        <label>Nazwa użytkownika</label>
        <input type="text" id="regUsername" placeholder="Wybierz login (min. 3 znaki)" autocomplete="username">
      </div>
      <div class="auth-field">
        <label>Email <span style="color:var(--text2);font-size:10px">(opcjonalne)</span></label>
        <div class="auth-email-wrap">
          <input type="text" id="regEmailPrefix" placeholder="twójemail" autocomplete="off" oninput="previewEmail(this.value)">
          <span class="auth-email-domain">@cs2-market.app</span>
        </div>
        <div class="auth-email-preview" id="emailPreview" style="display:none">
          Będziesz logować się też jako: <span id="emailPreviewText"></span>
        </div>
      </div>
      <div class="auth-field">
        <label>Hasło</label>
        <input type="password" id="regPassword" placeholder="Hasło (min. 6 znaków)" autocomplete="new-password" onkeydown="if(event.key==='Enter') doRegister()">
      </div>
      <div class="auth-field">
        <label>Link do profilu Steam <span style="color:var(--text2);font-size:10px">(opcjonalne)</span></label>
        <input type="text" id="regSteamId" placeholder="https://steamcommunity.com/id/nazwa">
      </div>
      <button class="auth-btn" onclick="doRegister()" id="registerBtn">ZAREJESTRUJ</button>
    </div>
    <div class="auth-error" id="authError"></div>
    <div class="auth-success" id="authSuccess"></div>
    <div style="margin-top:16px;text-align:center;border-top:1px solid var(--border);padding-top:16px">
      <span style="font-family:'Share Tech Mono',monospace;font-size:11px;color:var(--text2);letter-spacing:1px;text-transform:uppercase">lub</span>
      <button class="btn-guest" onclick="loginAsGuest()" style="margin-top:10px;width:100%;font-family:'Rajdhani',sans-serif;font-size:14px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;padding:10px;background:transparent;border:1px dashed var(--border2);border-radius:8px;color:var(--text2);cursor:pointer;transition:all 0.2s" onmouseover="this.style.borderColor='var(--accent)';this.style.color='var(--accent)'" onmouseout="this.style.borderColor='var(--border2)';this.style.color='var(--text2)'">
        Zaloguj jako gość
      </button>
      <div style="font-family:'Share Tech Mono',monospace;font-size:10px;color:var(--text2);opacity:0.6;margin-top:8px">Tryb demo · dane nie są zapisywane</div>
    </div>
  </div>
</div>

<!-- HEADER -->
<header class="app-header-wrap">
  <div class="container" style="display:flex;align-items:center;gap:16px;height:72px">
    <!-- LEWA: logo + nav -->
    <div style="display:flex;align-items:center;gap:0;flex-shrink:0">
      <a href="/" class="logo" style="margin-right:16px;text-decoration:none;display:flex;align-items:center;gap:10px">
        <img src="/logo.webp" alt="CS2 Market Logo" style="height:38px;width:38px;object-fit:contain;filter:drop-shadow(0 0 8px rgba(0,212,255,0.5))">
        <h1>CS2 <span>MARKET</span></h1>
      </a>
      <nav class="site-nav">
        <a href="/" class="site-nav-link">Strona główna</a>
        <a href="/kalkulator" class="site-nav-link">Kalkulator</a>
      </nav>
    </div>
    <!-- ŚRODEK: importuj + wartość portfela -->
    <div style="display:flex;align-items:center;gap:12px;flex:1;justify-content:flex-end">
      <button class="btn-import-header" onclick="toggleImportModal()">Importuj ekwipunek</button>
      <div class="total-value">
        <span class="total-label">Wartość portfela</span>
        <div style="display:flex;align-items:center;gap:10px;flex-wrap:nowrap;white-space:nowrap">
          <span class="total-amount" id="totalDisplay" style="white-space:nowrap">0,00 zł</span>
          <span id="totalChangeDisplay" style="display:none;font-family:'Share Tech Mono',monospace;font-size:12px;padding:3px 10px;border-radius:6px;font-weight:700;letter-spacing:0.5px;white-space:nowrap;flex-shrink:0"></span>
        </div>
      </div>
    </div>
    <!-- PRAWA: user + wyloguj -->
    <div style="display:flex;align-items:center;gap:8px;flex-shrink:0;border-left:1px solid var(--border);padding-left:14px">
      <span class="user-name" id="headerUsername"></span>
      <button class="btn-logout" onclick="doLogout()">Wyloguj</button>
    </div>
  </div>
</header>

<!-- IMPORT MODAL -->
<div id="importModal" class="import-modal" style="display:none" onclick="if(event.target===this)toggleImportModal()">
  <div class="import-modal-box">
    <div class="import-modal-header">
      <div class="import-modal-title">Importuj ekwipunek Steam CS2</div>
      <button class="import-modal-close" onclick="toggleImportModal()">✕</button>
    </div>
    <div class="import-steps">
      <div class="import-step">
        <div class="import-step-num">1</div>
        <div>
          <div class="import-step-title">Ustaw ekwipunek jako publiczny</div>
          <div class="import-step-desc">Wejdź w <a href="https://steamcommunity.com/my/edit/settings" target="_blank">Ustawienia prywatności Steam</a> i ustaw <b>Ekwipunek gry → Publiczny</b>.</div>
        </div>
      </div>
      <div class="import-step">
        <div class="import-step-num">2</div>
        <div>
          <div class="import-step-title">Znajdź swój Steam ID64</div>
          <div class="import-step-desc">Wejdź na swój profil Steam i użyj <a href="https://steamidfinder.com" target="_blank">steamidfinder.com</a> — skopiuj <b>steamID64</b> (17 cyfr).</div>
        </div>
      </div>
      <div class="import-step">
        <div class="import-step-num">3</div>
        <div>
          <div class="import-step-title">Wklej Steam ID64 i importuj</div>
        </div>
      </div>
    </div>
    <div class="import-form" style="margin-top:16px">
      <div class="input-group" style="flex:1">
        <input type="text" id="steamIdInput" placeholder="76561198..." autocomplete="off" onkeydown="if(event.key==='Enter') importInventory('replace')">
      </div>
    </div>
    <div style="display:flex;gap:8px;margin-top:10px;flex-wrap:wrap">
      <button class="btn-import" style="flex:1" onclick="importInventory('replace')" id="importBtn">Zastąp portfel</button>
      <button class="btn-import" style="flex:1;background:linear-gradient(135deg,#0088cc,#005588);color:#fff" onclick="importInventory('merge')" id="importMergeBtn">Dodaj do portfela</button>
    </div>
    <div id="importStatus" class="import-status" style="display:none"></div>
  </div>
</div>

<!-- MAIN APP -->
<div class="container" style="padding-top:32px">
  <div class="notice" id="errorNotice"></div>
  <div id="fileProtocolWarning" class="notice" style="display:none"></div>

  <div class="tabs">
    <button class="tab active" onclick="switchTab('add')" id="tab-add">Mój portfel</button>
    <button class="tab" onclick="switchTab('search')" id="tab-search">Wyszukiwarka skinów</button>
    <button class="tab" onclick="switchTab('trending')" id="tab-trending">Trending</button>
    <button class="tab" onclick="switchTab('history')" id="tab-history">Historia</button>
    <button class="tab" onclick="switchTab('ai')" id="tab-ai">AI Doradca</button>
  </div>

  <!-- Wersja mobilna zakładek — rozwijane menu zamiast przewijanego paska -->
  <div class="tabs-mobile" id="tabsMobile">
    <button class="tabs-mobile-toggle" onclick="toggleTabsMenu()" id="tabsMobileToggle">
      <span id="tabsMobileLabel">Mój portfel</span>
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" id="tabsMobileChevron"><path d="M6 9l6 6 6-6"></path></svg>
    </button>
    <div class="tabs-mobile-menu" id="tabsMobileMenu" style="display:none">
      <button class="tabs-mobile-item active" onclick="switchTabMobile('add')" id="tabmob-add">Mój portfel</button>
      <button class="tabs-mobile-item" onclick="switchTabMobile('search')" id="tabmob-search">Wyszukiwarka skinów</button>
      <button class="tabs-mobile-item" onclick="switchTabMobile('trending')" id="tabmob-trending">Trending</button>
      <button class="tabs-mobile-item" onclick="switchTabMobile('history')" id="tabmob-history">Historia</button>
      <button class="tabs-mobile-item" onclick="switchTabMobile('ai')" id="tabmob-ai">AI Doradca</button>
    </div>
  </div>

  <!-- AI -->
  <div id="panel-ai" style="display:none">
    <div class="ai-panel">
      <div class="ai-header">
        <div class="ai-avatar">AI</div>
        <div>
          <div class="ai-title">CS2 Market AI</div>
          <div class="ai-subtitle">Ekspert rynku Steam · Ma dostęp do Twojego portfela, cen i trendów</div>
        </div>
        <button class="ai-clear-btn" onclick="clearAiChat()">Wyczyść czat</button>
      </div>
      <div class="ai-suggestions">
        <div class="ai-suggest-label">Szybkie pytania:</div>
        <button class="ai-chip" onclick="askAI('Przeanalizuj mój portfel i powiedz co warto teraz sprzedać.')">Analizuj portfel</button>
        <button class="ai-chip" onclick="askAI('Co warto teraz kupić jako inwestycję na rynku CS2? Patrz na trending.')">Co kupić?</button>
        <button class="ai-chip" onclick="askAI('Które skiny w moim portfelu mają największy potencjał wzrostu?')">Potencjał wzrostu</button>
        <button class="ai-chip" onclick="askAI('Czy są jakieś skrzynki lub itemy które warto teraz obserwować?')">Gorące skrzynki</button>
        <button class="ai-chip" onclick="askAI('Jakie są ogólne zasady inwestowania w skiny CS2?')">Jak inwestować?</button>
      </div>
      <div class="ai-messages" id="aiMessages">
        <div class="ai-msg ai-msg-bot">
          <div class="ai-msg-content">Cześć! Jestem Twoim osobistym doradcą rynku CS2. Mam wgląd w Twój portfel, aktualne ceny i trendy Steam. Zadaj mi pytanie!</div>
        </div>
      </div>
      <div class="ai-input-row">
        <input type="text" id="aiInput" class="ai-input" placeholder="Zapytaj o rynek CS2, inwestycje, skiny..." onkeydown="if(event.key==='Enter' && !event.shiftKey){event.preventDefault();sendAiMessage();}">
        <button class="ai-send-btn" onclick="sendAiMessage()" id="aiSendBtn"><span>Wyślij</span></button>
      </div>
    </div>
  </div>

  <!-- ADD -->
  <div id="panel-add">
    <div class="add-toggle-bar">
      <button class="btn-add-toggle" id="addToggleBtn" onclick="toggleAddForm()">+ Dodaj skin</button>
    </div>
    <div class="add-section" id="addFormWrap" style="display:none">
      <div class="add-form">
        <div class="input-group" style="position:relative">
          <input type="text" id="itemNameInput" placeholder="Np. AK-47 | Redline (Field-Tested)" autocomplete="off" oninput="onItemInput(this)">
          <div class="suggestions" id="suggestions" style="display:none"></div>
        </div>
        <div class="input-group input-small">
          <input type="number" id="itemQtyInput" placeholder="Ilość" min="1" value="1" style="width:100%">
        </div>
        <button class="btn btn-primary" onclick="addItem()">+ DODAJ</button>
      </div>
      <div class="wear-guide">
        <span class="wear-guide-label">Stopnie zużycia:</span>
        <span class="wear-chip" onclick="insertWear('Factory New')">Prosto z Fabryki = <b>Factory New</b></span>
        <span class="wear-chip" onclick="insertWear('Minimal Wear')">Lekkie Zużycie = <b>Minimal Wear</b></span>
        <span class="wear-chip" onclick="insertWear('Field-Tested')">Po Testach Bojowych = <b>Field-Tested</b></span>
        <span class="wear-chip" onclick="insertWear('Well-Worn')">Mocne Zużycie = <b>Well-Worn</b></span>
        <span class="wear-chip" onclick="insertWear('Battle-Scarred')">Po Ciężkich Walkach = <b>Battle-Scarred</b></span>
      </div>
    </div>
  </div>

  <!-- SEARCH -->
  <div class="add-section" id="panel-search" style="display:none">
    <div class="add-form" style="margin-bottom:16px">
      <div class="input-group" style="flex:1">
        <input type="text" id="searchInput" placeholder="Wpisz nazwę broni, np. AK-47, AWP, Knife..." autocomplete="off" onkeydown="if(event.key==='Enter') doSearch()">
      </div>
      <div class="input-group" style="flex:0 0 160px">
        <select id="searchSort" style="width:100%;background:var(--bg3);border:1px solid var(--border2);border-radius:8px;padding:10px 12px;font-family:Rajdhani,sans-serif;font-size:14px;color:var(--text);outline:none;cursor:pointer">
          <option value="price_asc">Cena: rosnąco</option>
          <option value="price_desc">Cena: malejąco</option>
          <option value="name">Nazwa A-Z</option>
          <option value="popular">Popularność</option>
        </select>
      </div>
      <button class="btn btn-primary" onclick="doSearch()">SZUKAJ</button>
    </div>
    <div id="searchResults" class="search-results-grid"></div>
    <div id="searchPager" style="display:flex;gap:8px;justify-content:center;margin-top:16px;flex-wrap:wrap"></div>
  </div>

  <!-- TRENDING -->
  <div id="panel-trending" style="display:none">
    <div class="trending-header">
      <div>
        <div class="section-title" style="margin-bottom:4px">Trending — Gorące przedmioty CS2</div>
        <div style="font-size:13px;color:var(--text2);margin-bottom:16px">Posortowane po wolumenie sprzedaży z ostatnich 24h.</div>
      </div>
      <div style="display:flex;gap:8px;flex-wrap:wrap;margin-bottom:16px">
        <button class="filter-btn active" id="tcat-all" onclick="loadTrending('all')">Wszystko</button>
        <button class="filter-btn" id="tcat-rifle" onclick="loadTrending('rifle')">Karabiny</button>
        <button class="filter-btn" id="tcat-knife" onclick="loadTrending('knife')">Noże</button>
        <button class="filter-btn" id="tcat-case" onclick="loadTrending('case')">Skrzynki</button>
        <button class="filter-btn" id="tcat-gloves" onclick="loadTrending('gloves')">Rękawice</button>
        <button class="filter-btn" id="tcat-pistol" onclick="loadTrending('pistol')">Pistolety</button>
      </div>
    </div>
    <div id="trendingResults" class="search-results-grid"></div>
    <div id="trendingPager" style="display:flex;gap:8px;justify-content:center;margin-top:16px;flex-wrap:wrap"></div>
  </div>

  <!-- WALLET (stats + filters + grid) -->
  <div id="panel-wallet">
    <div class="toolbar">
      <div class="toolbar-stats">
        <div class="stat-pill">
          <span class="stat-pill-label">Przedmioty</span>
          <span class="stat-pill-value" id="statItems">0</span>
        </div>
        <div class="stat-pill">
          <span class="stat-pill-label">Szt.</span>
          <span class="stat-pill-value" id="statQty">0</span>
        </div>
        <div class="stat-pill stat-pill-top">
          <span class="stat-pill-label">Najdroższy</span>
          <span class="stat-pill-value" id="statTop">—</span>
        </div>
      </div>
      <div class="toolbar-filters">
        <select class="filter-select" id="sortSelect" onchange="setSort(this.value)" title="Sortuj">
          <option value="default">Sortuj</option>
          <option value="price_desc">Cena ↓</option>
          <option value="price_asc">Cena ↑</option>
          <option value="qty_desc">Ilość ↓</option>
          <option value="qty_asc">Ilość ↑</option>
          <option value="name">A–Z</option>
        </select>
        <select class="filter-select" id="catSelect" onchange="setCategory(this.value)" title="Kategoria">
          <option value="all">Kategoria</option>
          <option value="weapon">Bronie</option>
          <option value="knife">Noże</option>
          <option value="gloves">Rękawice</option>
          <option value="case">Skrzynki</option>
          <option value="capsule">Kapsuły</option>
          <option value="sticker">Naklejki</option>
          <option value="other">Inne</option>
        </select>
      </div>
      <div class="toolbar-actions">
        <button class="btn btn-refresh-all" id="refreshAllBtn" onclick="refreshAllItems()"><span id="refreshAllIcon">⟳</span> Odśwież</button>
        <button class="btn-stop-refresh" id="stopRefreshBtn" onclick="stopRefresh()" style="display:none">Stop</button>
        <button class="btn-share-portfolio" onclick="openShareModal()">Udostępnij</button>
      </div>
    </div>
    <div class="items-grid" id="itemsGrid">
      <div class="empty-state">
        <div class="empty-icon"></div>
        <div class="empty-title">Brak przedmiotów</div>
        <div class="empty-sub">Dodaj swoje skiny CS2 powyżej</div>
      </div>
    </div>
  </div>

  <!-- HISTORIA -->
  <div id="panel-history" style="display:none">
    <div class="history-header">
      <div>
        <div class="section-title" style="margin-bottom:4px">Historia wartości portfela</div>
        <div style="font-size:13px;color:var(--text2);margin-bottom:16px">Dzienny snapshot wartości Twojego portfela. Dane przechowywane przez 90 dni.</div>
      </div>
      <button class="btn btn-primary" onclick="takeSnapshot()" id="snapshotBtn" style="height:40px;white-space:nowrap">Zapisz teraz</button>
    </div>
    <div class="history-range-bar">
      <button class="filter-btn active" id="hrange-7" onclick="setHistoryRange(7)">7 dni</button>
      <button class="filter-btn" id="hrange-30" onclick="setHistoryRange(30)">30 dni</button>
      <button class="filter-btn" id="hrange-90" onclick="setHistoryRange(90)">90 dni</button>
    </div>
    <div class="history-chart-wrap">
      <canvas id="historyChart"></canvas>
      <div class="history-empty" id="historyEmpty" style="display:none">
        <div style="font-size:32px;margin-bottom:12px">📊</div>
        <div style="font-family:'Orbitron',monospace;font-size:14px;color:var(--text2)">Brak danych historycznych</div>
        <div style="font-size:13px;color:var(--text2);margin-top:8px;opacity:0.7">Kliknij "Zapisz teraz" aby utworzyć pierwszy snapshot</div>
      </div>
    </div>
    <div class="history-stats-row" id="historyStats" style="display:none">
      <div class="history-stat-card"><div class="history-stat-label">Najwyższa wartość</div><div class="history-stat-value" id="hstat-max" style="color:#39ff14">—</div></div>
      <div class="history-stat-card"><div class="history-stat-label">Najniższa wartość</div><div class="history-stat-value" id="hstat-min" style="color:#ff6b6b">—</div></div>
      <div class="history-stat-card"><div class="history-stat-label">Zmiana w okresie</div><div class="history-stat-value" id="hstat-change">—</div></div>
      <div class="history-stat-card"><div class="history-stat-label">Liczba snapshotów</div><div class="history-stat-value" id="hstat-count" style="color:var(--accent)">—</div></div>
    </div>
    <div class="history-table-wrap" id="historyTableWrap" style="display:none">
      <div class="section-title" style="font-size:14px;margin-bottom:12px">Dziennik</div>
      <table class="history-table">
        <thead><tr><th>Data</th><th>Wartość portfela</th><th>Liczba skinów</th><th>Zmiana</th></tr></thead>
        <tbody id="historyTableBody"></tbody>
      </table>
    </div>
  </div>
</div>

<!-- SHARE MODAL -->
<div id="shareModal" style="display:none;position:fixed;inset:0;z-index:1000;background:rgba(0,0,0,0.7);backdrop-filter:blur(4px)" onclick="if(event.target===this)closeShareModal()">
  <div style="position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);background:var(--bg2);border:1px solid var(--border2);border-radius:20px;padding:28px;width:min(420px,92vw)">
