let trendingLoaded=false, trendingPage=0, trendingCategory='all', trendingTotal=0, trendingCache=[];
const TREND_PAGE_SIZE = 20;
const TREND_QUERIES = { all:'', rifle:'AK-47 M4A4 M4A1-S AWP', knife:'Knife', case:'Case', gloves:'Gloves Wraps', pistol:'Glock USP Desert Eagle' };

async function loadTrending(category='all', page=0) {
  trendingCategory=category; trendingPage=page; trendingLoaded=true;
  document.querySelectorAll('[id^="tcat-"]').forEach(b => b.classList.remove('active'));
  const catBtn = document.getElementById('tcat-'+category); if (catBtn) catBtn.classList.add('active');
  const box = document.getElementById('trendingResults');
  box.innerHTML = '<div class="search-loading">Ładuję gorące itemy...</div>';
  document.getElementById('trendingPager').innerHTML = '';
  const query = TREND_QUERIES[category] || '';
  const start = page * TREND_PAGE_SIZE;
  const url = `https://steamcommunity.com/market/search/render/?appid=730&norender=1&search_descriptions=0&query=${encodeURIComponent(query)}&start=${start}&count=${TREND_PAGE_SIZE}&sort_column=popular&sort_dir=desc`;
  try {
    const data = await steamFetch(url);
    if (!data.success || !data.results?.length) { box.innerHTML = '<div class="search-empty">Brak wyników.</div>'; return; }
    trendingTotal = data.total_count || data.results.length;
    renderTrending(data.results); renderTrendingPager();
  } catch(e) { box.innerHTML = `<div class="search-empty">Błąd: ${escapeHtml(e.message)}</div>`; }
}

function renderTrending(results) {
  const box = document.getElementById('trendingResults'); trendingCache = [];
  const maxVol = Math.max(...results.map(r => parseInt(r.sell_listings)||0), 1);
  box.innerHTML = results.map((r, idx) => {
    const iconUrl = r.asset_description?.icon_url || '';
    const imgSrc = iconUrl ? `https://community.cloudflare.steamstatic.com/economy/image/${iconUrl}/200fx125f` : '';
    const cents = r.sell_price || 0; const priceNum = parseFloat(((cents/100)*STEAM_USD_PLN).toFixed(2));
    const priceDisplay = cents > 0 ? priceNum.toFixed(2).replace('.',',') + ' zł' : '—';
    const vol = parseInt(r.sell_listings)||0; const volRatio = vol/maxVol;
    const hotLevel = volRatio > 0.6 ? 'fire' : volRatio > 0.25 ? 'warm' : '';
    const hotLabel = volRatio > 0.6 ? 'HOT' : volRatio > 0.25 ? 'Rosnący' : '';
    const name = r.name || ''; const weaponName = name.includes('|') ? name.split('|')[0].trim() : name;
    const skinName = name.includes('|') ? name.split('|')[1].replace(/\(.*\)/,'').trim() : '';
    const inPortfolio = items.some(i => i.name === name);
    const rank = trendingPage * TREND_PAGE_SIZE + idx + 1;
    const dataIdx = trendingCache.length;
    trendingCache.push({ name, priceRaw: priceDisplay, priceNum, iconUrl });
    return `<div class="search-card" style="position:relative;animation-delay:${idx<10?idx*45:0}ms">
      <div style="position:absolute;top:8px;left:8px;z-index:2;display:flex;flex-direction:column;gap:4px">
        <div style="font-family:'Orbitron',monospace;font-size:10px;color:var(--text2);background:rgba(0,0,0,0.7);padding:2px 6px;border-radius:4px">#${rank}</div>
        ${hotLabel ? `<div class="trend-hot-badge ${hotLevel}">${hotLabel}</div>` : ''}
      </div>
      ${imgSrc ? `<img class="search-card-img" src="${imgSrc}" onerror="this.style.opacity=0.1" loading="lazy">` : '<div class="search-card-img" style="opacity:0.1"></div>'}
      <div style="font-family:'Share Tech Mono',monospace;font-size:10px;color:var(--text2);text-transform:uppercase;margin-top:4px">${escapeHtml(weaponName)}</div>
      <div class="search-card-name">${escapeHtml(skinName||name)}</div>
      <div class="search-card-price">${escapeHtml(priceDisplay)}</div>
      <div class="trend-vol">Oferty: <span>${vol.toLocaleString('pl-PL')}</span></div>
      <div class="search-card-add ${inPortfolio?'added':''}" onclick="addFromTrending(${dataIdx},this)">${inPortfolio?'W portfelu':'+ Dodaj do portfela'}</div>
    </div>`;
  }).join('');
}

async function addFromTrending(idx, btn) {
  const r = trendingCache[idx]; if (!r) return;
  const { name, priceRaw, priceNum, iconUrl } = r;
  const exists = items.find(i => i.name === name);
  if (exists) { exists.qty += 1; if (iconUrl && !exists.iconUrl) exists.iconUrl = iconUrl; saveItems(); renderItems(); btn.textContent='W portfelu'; btn.className='search-card-add added'; return; }
  items.push({ id: Date.now(), name, qty:1, price: priceNum>0?priceNum:null, priceRaw: priceNum>0?priceRaw:null, iconUrl, loading:false });
  saveItems(); renderItems(); btn.textContent='W portfelu'; btn.className='search-card-add added';
}

function renderTrendingPager() {
  const pager = document.getElementById('trendingPager'); const totalPages = Math.ceil(trendingTotal/TREND_PAGE_SIZE); if (totalPages<=1){pager.innerHTML='';return;}
  const pages=[]; for(let i=0;i<totalPages&&i<7;i++) pages.push(i);
  pager.innerHTML=[trendingPage>0?`<button class="pager-btn" onclick="loadTrending('${trendingCategory}',${trendingPage-1})">← Poprzednia</button>`:'', ...pages.map(p=>`<button class="pager-btn ${p===trendingPage?'active':''}" onclick="loadTrending('${trendingCategory}',${p})">${p+1}</button>`), trendingPage<totalPages-1?`<button class="pager-btn" onclick="loadTrending('${trendingCategory}',${trendingPage+1})">Następna →</button>`:''].join('');
}

// ── AI ────────────────────────────────────────────────────────
let aiHistory = [];

function buildMarketContext() {
  const total = items.reduce((s, i) => s + (i.price||0)*i.qty, 0);
  const portfolioStr = items.length===0 ? 'Portfel jest pusty.' : items.map(item => {
    const totalVal = ((item.price||0)*item.qty).toFixed(2); let changeStr='';
    const chg = getPriceChange(item);
    if (chg!==null) changeStr = ` | zmiana vs wczoraj: ${chg>0?'+':''}${chg.toFixed(1)}% (wczoraj: ${item.snapshotPrice.toFixed(2)} zł)`;
    return `- ${item.name}: ${item.priceRaw||(item.price?.toFixed(2)+' zł')||'brak ceny'} x${item.qty} = ${totalVal} zł${changeStr}`;
  }).join('\n');
  const trendStr = trendingCache.length>0 ? trendingCache.slice(0,15).map((r,i)=>`${i+1}. ${r.name} — ${r.priceRaw}`).join('\n') : 'Trending nie zostało załadowane.';
  return `Jesteś doświadczonym długoterminowym inwestorem na rynku skinów CS2. Patrzysz na perspektywę tygodni i miesięcy, nie godzin. Nie panikujesz z powodu chwilowych wahań.\n\nPORTFEL UŻYTKOWNIKA (łączna wartość: ${total.toFixed(2)} zł):\n${portfolioStr}\n\nAKTUALNIE TRENDING NA STEAM:\n${trendStr}\n\nOdpowiadaj po polsku. Bądź konkretny.`;
}

function addAiMessage(role, text, isTyping=false) {
  const box = document.getElementById('aiMessages');
  const div = document.createElement('div');
  div.className = `ai-msg ai-msg-${role==='user'?'user':'bot'}`;
  div.id = isTyping ? 'ai-typing' : '';
  div.innerHTML = `<div class="ai-msg-content">${text.replace(/\n/g,'<br>').replace(/\*\*(.*?)\*\*/g,'<strong>$1</strong>').replace(/\*(.*?)\*/g,'<em>$1</em>')}</div>`;
  box.appendChild(div); box.scrollTop = box.scrollHeight; return div;
}

function clearAiChat() {
  aiHistory = [];
  document.getElementById('aiMessages').innerHTML = '<div class="ai-msg ai-msg-bot"><div class="ai-msg-content">Czat wyczyszczony. W czym mogę pomóc?</div></div>';
}

async function askAI(text) { document.getElementById('aiInput').value = text; await sendAiMessage(); }

async function sendAiMessage() {
  const input = document.getElementById('aiInput'); const text = input.value.trim(); if (!text) return;
  const sendBtn = document.getElementById('aiSendBtn'); input.value = ''; sendBtn.disabled=true; sendBtn.innerHTML='<span>⟳</span>';
  addAiMessage('user', text); aiHistory.push({role:'user',content:text});
  if (aiHistory.length > 20) aiHistory = aiHistory.slice(-20);
  addAiMessage('bot', '⟳ Analizuję dane rynkowe...', true);
  try {
    const systemPrompt = buildMarketContext();
    const FREE_MODELS = ['openrouter/auto','deepseek/deepseek-r1:free','meta-llama/llama-4-scout:free','google/gemini-2.0-flash-exp:free','deepseek/deepseek-v3-base:free'];
    let reply=null, lastError='';
    for (const model of FREE_MODELS) {
      try {
        const response = await fetch(`${SUPABASE_FUNCTIONS_URL}/ai-chat`, { method:'POST', headers:{'Content-Type':'application/json','apikey':SUPABASE_KEY,'Authorization':`Bearer ${SUPABASE_KEY}`}, body:JSON.stringify({model, messages:[{role:'system',content:systemPrompt},...aiHistory]}) });
        const data = await response.json();
        if (response.ok && data.choices?.[0]?.message?.content) { reply=data.choices[0].message.content; break; }
        lastError = data?.error?.message || `HTTP ${response.status}`;
      } catch(e) { lastError=e.message; }
      await new Promise(r=>setTimeout(r,800));
    }
    if (!reply) throw new Error('Wszystkie modele niedostępne. ' + lastError);
    const typing = document.getElementById('ai-typing'); if (typing) typing.remove();
    aiHistory.push({role:'assistant',content:reply}); addAiMessage('bot', reply);
  } catch(e) { const typing=document.getElementById('ai-typing'); if(typing)typing.remove(); addAiMessage('bot','Błąd: '+e.message); }
  sendBtn.disabled=false; sendBtn.innerHTML='<span>Wyślij</span>';
  document.getElementById('aiMessages').scrollTop = 9999;
}

// ── IMPORT ────────────────────────────────────────────────────
function toggleImportModal() {
  const modal = document.getElementById('importModal'); const isOpen = modal.style.display!=='none';
  modal.style.display = isOpen ? 'none' : 'flex'; if (!isOpen) document.getElementById('steamIdInput').focus();
}

async function extractSteamId(input) {
  if (!input) return null; const trimmed = input.trim();
  if (/^\d{17}$/.test(trimmed)) return trimmed;
  const profileMatch = trimmed.match(/profiles\/(\d{17})/); if (profileMatch) return profileMatch[1];
  const vanityMatch = trimmed.match(/id\/([^\/]+)/);
  if (vanityMatch) { const data = await steamFetch(`https://api.steampowered.com/ISteamUser/ResolveVanityURL/v1/?key=${STEAM_API_KEY}&vanityurl=${vanityMatch[1]}`); if (data.response.success===1) return data.response.steamid; }
  return null;
}

async function importInventory(mode='replace') {
  const input = document.getElementById('steamIdInput').value.trim();
  const steamId = await extractSteamId(input);
  if (!steamId) { setImportStatus('error','Podaj poprawny link lub Steam ID'); return; }
  const btn=document.getElementById('importBtn'), btn2=document.getElementById('importMergeBtn');
  btn.disabled=true; btn2.disabled=true; setImportStatus('loading','⟳ Pobieranie ekwipunku Steam...');
  try {
    const data = await steamFetch(`https://steamcommunity.com/inventory/${steamId}/730/2?l=english&count=500`);
    if (!data || data.error) throw new Error(data?.error||'Nie można pobrać ekwipunku. Sprawdź czy jest publiczny.');
    if (!data.assets || data.assets.length===0) { setImportStatus('error','Ekwipunek jest pusty lub prywatny.'); btn.disabled=false; btn2.disabled=false; return; }
    const descriptions = {}; (data.descriptions||[]).forEach(d => { descriptions[`${d.classid}_${d.instanceid}`]=d; });
    const skinMap = {};
    (data.assets||[]).forEach(asset => {
      const desc = descriptions[`${asset.classid}_${asset.instanceid}`]; if (!desc||!desc.marketable) return;
      const name = desc.market_hash_name; if (!name) return;
      if (skinMap[name]) skinMap[name].qty++; else skinMap[name]={name,qty:1,iconUrl:desc.icon_url||''};
    });
    const newSkins = Object.values(skinMap);
    if (newSkins.length===0) { setImportStatus('error','Nie znaleziono skinów CS2.'); btn.disabled=false; btn2.disabled=false; return; }
    if (mode==='replace') items=[];
    let added=0, updated=0;
    newSkins.forEach(skin => {
      const exists=items.find(i=>i.name===skin.name);
      if (exists) { exists.qty+=skin.qty; exists.iconUrl=exists.iconUrl||skin.iconUrl; updated++; }
      else { items.push({id:Date.now()+Math.random(),name:skin.name,qty:skin.qty,price:null,priceRaw:null,iconUrl:skin.iconUrl,loading:false}); added++; }
    });
    saveItems(); renderItems();
    setImportStatus('success',`${mode==='replace'?'Zastąpiono':'Dodano'}: ${added+updated} skinów. Pobieram ceny...`);
    await autoFetchAllPrices(); toggleImportModal();
  } catch(e) { setImportStatus('error','Błąd: '+e.message); }
  btn.disabled=false; btn2.disabled=false;
}

async function autoFetchAllPrices() {
  refreshStopped=false;
  const btn=document.getElementById('refreshAllBtn'), stopBtn=document.getElementById('stopRefreshBtn');
  const unpricedItems = items.filter(i=>i.price===null);
  if (btn) { btn.disabled=true; btn.classList.add('spinning'); btn.innerHTML=`<span style="display:inline-block;animation:spin 0.8s linear infinite">⟳</span> 0/${unpricedItems.length}`; }
  if (stopBtn) stopBtn.style.display='block';
  const BATCH=2; let done=0;
  for (let i=0;i<unpricedItems.length;i+=BATCH) {
    if (refreshStopped) break;
    const batch=unpricedItems.slice(i,i+BATCH); batch.forEach(item=>{item.loading=true;}); renderItems();
    await Promise.all(batch.map(async item=>{
      const result=await fetchPrice(item.name); item.loading=false; updateItemPrice(item,result);
      if(result&&result.iconUrl)item.iconUrl=result.iconUrl; done++;
      if(btn)btn.innerHTML=`<span style="display:inline-block;animation:spin 0.8s linear infinite">⟳</span> ${done}/${unpricedItems.length}`;
    }));
    saveItems(); renderItems();
    if(i+BATCH<unpricedItems.length&&!refreshStopped) await new Promise(r=>setTimeout(r,900));
  }
  if(btn){btn.disabled=false;btn.classList.remove('spinning');btn.innerHTML='<span>⟳</span> Gotowe!';}
  if(stopBtn)stopBtn.style.display='none';
}

function setImportStatus(type, msg) {
  const el=document.getElementById('importStatus'); el.style.display='block';
  el.style.background=type==='error'?'rgba(255,68,68,0.1)':type==='success'?'rgba(57,255,20,0.08)':'rgba(0,212,255,0.08)';
  el.style.border=`1px solid ${type==='error'?'rgba(255,68,68,0.3)':type==='success'?'rgba(57,255,20,0.3)':'rgba(0,212,255,0.2)'}`;
  el.style.color=type==='error'?'#ff4444':type==='success'?'#39ff14':'#00d4ff';
  el.style.padding='10px 14px'; el.style.borderRadius='8px'; el.style.fontSize='13px';
  el.textContent=msg;
}

