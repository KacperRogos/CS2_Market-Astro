 border-radius: 12px;
 display: flex;
 align-items: center;
 justify-content: center;
 flex-shrink: 0;
 }

 .ai-title {
 font-family: 'Orbitron', monospace;
 font-size: 14px;
 font-weight: 700;
 color: var(--accent);
 }

 .ai-subtitle {
 font-size: 12px;
 color: var(--text2);
 margin-top: 2px;
 }

 .ai-clear-btn {
 margin-left: auto;
 background: transparent;
 border: 1px solid var(--border2);
 color: var(--text2);
 border-radius: 6px;
 padding: 6px 12px;
 font-size: 12px;
 cursor: pointer;
 transition: all 0.2s;
 white-space: nowrap;
 }

 .ai-clear-btn:hover { border-color: #ff4444; color: #ff4444; }

 .ai-suggestions {
 display: flex;
 align-items: center;
 gap: 8px;
 padding: 10px 16px;
 border-bottom: 1px solid var(--border);
 flex-wrap: wrap;
 flex-shrink: 0;
 background: var(--bg3);
 }

 .ai-suggest-label {
 font-family: 'Share Tech Mono', monospace;
 font-size: 10px;
 color: var(--text2);
 text-transform: uppercase;
 letter-spacing: 1px;
 white-space: nowrap;
 }

 .ai-chip {
 font-family: 'Rajdhani', sans-serif;
 font-size: 12px;
 font-weight: 600;
 padding: 5px 12px;
 background: var(--bg2);
 border: 1px solid var(--border2);
 border-radius: 20px;
 color: var(--text);
 cursor: pointer;
 transition: all 0.2s;
 white-space: nowrap;
 }

 .ai-chip:hover {
 border-color: var(--accent);
 color: var(--accent);
 background: rgba(0,212,255,0.06);
 }

 .ai-messages {
 flex: 1;
 overflow-y: auto;
 padding: 16px;
 display: flex;
 flex-direction: column;
 gap: 12px;
 }

 .ai-msg { display: flex; gap: 10px; }

 .ai-msg-bot { align-items: flex-start; }
 .ai-msg-user { align-items: flex-start; flex-direction: row-reverse; }

 .ai-msg-content {
 max-width: 75%;
 padding: 12px 16px;
 border-radius: 12px;
 font-size: 14px;
 line-height: 1.6;
 white-space: pre-wrap;
 }

 .ai-msg-bot .ai-msg-content {
 background: var(--bg3);
 border: 1px solid var(--border);
 color: var(--text);
 border-top-left-radius: 2px;
 }

 .ai-msg-user .ai-msg-content {
 background: rgba(0,212,255,0.1);
 border: 1px solid rgba(0,212,255,0.25);
 color: var(--text);
 border-top-right-radius: 2px;
 }

 .ai-msg-typing .ai-msg-content {
 color: var(--text2);
 animation: blink 1.2s ease-in-out infinite;
 }

 .ai-input-row {
 display: flex;
 gap: 10px;
 padding: 14px 16px;
 border-top: 1px solid var(--border);
 flex-shrink: 0;
 }

 .ai-input {
 flex: 1;
 background: var(--bg3);
 border: 1px solid var(--border2);
 border-radius: 8px;
 padding: 10px 16px;
 font-family: 'Rajdhani', sans-serif;
 font-size: 14px;
 color: var(--text);
 outline: none;
 transition: border-color 0.2s, box-shadow 0.2s;
 }

 .ai-input:focus {
 border-color: var(--accent);
 box-shadow: var(--glow);
 }

 .ai-input::placeholder { color: var(--text2); }

 .ai-send-btn {
 font-family: 'Rajdhani', sans-serif;
 font-size: 14px;
 font-weight: 700;
 letter-spacing: 1px;
 padding: 10px 22px;
 background: linear-gradient(135deg, var(--accent), #0088cc);
 border: none;
 border-radius: 8px;
 color: #000;
 cursor: pointer;
 transition: all 0.2s;
 white-space: nowrap;
 }

 .ai-send-btn:hover { box-shadow: var(--glow); transform: translateY(-1px); }
 .ai-send-btn:disabled { opacity: 0.5; cursor: not-allowed; transform: none; }

 /* Trending */
 .trending-header { }

 .trend-hot-badge {
