 border: 1px solid rgba(255,107,53,0.3);
 border-radius: 8px;
 padding: 12px 16px;
 font-size: 13px;
 color: var(--accent2);
 margin-bottom: 16px;
 display: none;
 }

 .notice.show { display: block; }

 /* Stats bar */
 .stats-bar {
 display: flex;
 gap: 16px;
 margin-bottom: 24px;
 flex-wrap: wrap;
 }

 .stat-card {
 background: var(--bg2);
 border: 1px solid var(--border);
 border-radius: 8px;
 padding: 12px 20px;
 display: flex;
 flex-direction: column;
 gap: 4px;
 }

 .stat-label {
 font-family: 'Share Tech Mono', monospace;
 font-size: 10px;
 color: var(--text2);
 text-transform: uppercase;
 letter-spacing: 2px;
 }

 .stat-value {
 font-family: 'Orbitron', monospace;
 font-size: 20px;
 font-weight: 700;
 color: #fff;
 }

 /* Ukryj strzałki w input[type=number] */
 input[type=number]::-webkit-inner-spin-button,
 input[type=number]::-webkit-outer-spin-button { -webkit-appearance: none; margin: 0; }
 input[type=number] { -moz-appearance: textfield; }

 scrollbar-width: thin;
 ::-webkit-scrollbar { width: 6px; }
 ::-webkit-scrollbar-track { background: var(--bg); }
 ::-webkit-scrollbar-thumb { background: var(--border2); border-radius: 3px; }

 /* Tabs */
 .tabs {
 display: flex;
 gap: 4px;
 margin-bottom: 16px;
 background: var(--bg2);
 border: 1px solid var(--border);
 border-radius: 10px;
 padding: 4px;
 width: fit-content;
 }

 .tab {
 font-family: 'Rajdhani', sans-serif;
 font-size: 14px;
 font-weight: 700;
 letter-spacing: 1px;
 padding: 8px 20px;
 border: none;
 border-radius: 7px;
 cursor: pointer;
 background: transparent;
 color: var(--text2);
 transition: color 0.2s ease, background 0.2s ease, transform 0.15s ease, box-shadow 0.2s ease;
 }

 .tab.active {
 background: var(--bg3);
 color: var(--accent);
 border: 1px solid var(--border2);
 box-shadow: var(--glow);
 }

 .tab:hover:not(.active) { color: var(--text); transform: translateY(-1px); }

 /* Mobilne dropdown menu zakładek — domyślnie ukryte, pokazywane tylko <600px */
 .tabs-mobile { display: none; position: relative; margin-bottom: 16px; }

 .tabs-mobile-toggle {
   width: 100%;
   display: flex;
   align-items: center;
   justify-content: space-between;
   background: var(--bg2);
   border: 1px solid var(--border);
   border-radius: 10px;
   padding: 12px 16px;
   color: var(--accent);
   font-family: 'Rajdhani', sans-serif;
   font-size: 14px;
   font-weight: 700;
   letter-spacing: 1px;
   cursor: pointer;
 }

 .tabs-mobile-toggle svg { transition: transform 0.2s ease; flex-shrink: 0; }

 .tabs-mobile-menu {
   position: absolute;
   top: calc(100% + 6px);
   left: 0;
   right: 0;
   z-index: 50;
   background: var(--bg2);
   border: 1px solid var(--border2);
   border-radius: 10px;
   padding: 6px;
   box-shadow: 0 12px 30px rgba(0,0,0,0.5);
   display: flex;
   flex-direction: column;
   gap: 2px;
 }

 .tabs-mobile-item {
   text-align: left;
   background: transparent;
   border: none;
   color: var(--text2);
   padding: 11px 12px;
   border-radius: 7px;
   font-family: 'Rajdhani', sans-serif;
   font-size: 14px;
   font-weight: 600;
   cursor: pointer;
 }

 .tabs-mobile-item:active { background: var(--bg3); }
 .tabs-mobile-item.active { color: var(--accent); background: var(--bg3); }

 /* Search results */
 .search-results-grid {
 display: grid;
 grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
 gap: 12px;
 }
 .qty-control {
 display: flex;
 align-items: center;
 gap: 6px;
 margin-left: auto;
}

.qty-control button {
 background: #0f172a;
 border: 1px solid rgba(255,255,255,0.1);
 color: #00ffa6;
 width: 26px;
 height: 26px;
 border-radius: 6px;
 cursor: pointer;
 transition: 0.2s;
 font-size: 16px;
}

.qty-control button:hover {
 background: #00ffa6;
 color: black;
}

.qty-control span {
 min-width: 22px;
 text-align: center;
 font-weight: 600;
}

 .search-card {
 background: var(--bg3);
 border: 1px solid var(--border);
 border-radius: 10px;
 padding: 12px;
 display: flex;
 flex-direction: column;
 gap: 8px;
 cursor: pointer;
 transition: transform 0.2s cubic-bezier(0.34,1.56,0.64,1), box-shadow 0.2s ease, border-color 0.2s ease;
 animation: fadeInCard 0.35s ease both;
 }

 .search-card:hover {
 border-color: var(--accent);
 box-shadow: var(--glow), 0 12px 32px rgba(0,0,0,0.4);
 transform: translateY(-5px) scale(1.02);
 }

 .search-card-img {
 width: 100%;
 height: 80px;
 object-fit: contain;
 background: var(--bg2);
 border-radius: 6px;
 padding: 4px;
 }

 .search-card-name {
 font-size: 12px;
 font-weight: 600;
 color: var(--text);
 line-height: 1.3;
 display: -webkit-box;
 -webkit-line-clamp: 2;
 -webkit-box-orient: vertical;
 overflow: hidden;
 }

 .search-card-price {
 font-family: 'Orbitron', monospace;
 font-size: 14px;
 font-weight: 700;
 color: var(--accent3);
 }

 .search-card-vol {
 font-family: 'Share Tech Mono', monospace;
 font-size: 10px;
 color: var(--text2);
 }

 .search-card-add {
 font-family: 'Rajdhani', sans-serif;
 font-size: 12px;
 font-weight: 700;
 letter-spacing: 1px;
 padding: 6px;
 background: rgba(0,212,255,0.1);
 border: 1px solid rgba(0,212,255,0.3);
 border-radius: 6px;
 color: var(--accent);
 cursor: pointer;
 transition: background 0.2s, box-shadow 0.2s, transform 0.15s ease;
 text-align: center;
 }

 .search-card-add:hover {
 background: rgba(0,212,255,0.2);
 box-shadow: var(--glow);
 transform: translateY(-1px);
 }

 .search-card-add:active { transform: scale(0.95); }

 .search-card-add.added {
 background: rgba(57,255,20,0.1);
 border-color: rgba(57,255,20,0.3);
 color: var(--accent3);
 }

 .search-empty {
 grid-column: 1/-1;
 text-align: center;
 padding: 40px;
 color: var(--text2);
 font-size: 14px;
 }

 .search-loading {
 grid-column: 1/-1;
 text-align: center;
 padding: 40px;
 color: var(--text2);
 font-family: 'Share Tech Mono', monospace;
 font-size: 13px;
 animation: blink 1s ease-in-out infinite;
 }

 .pager-btn {
 font-family: 'Share Tech Mono', monospace;
 font-size: 12px;
 padding: 6px 14px;
 background: var(--bg3);
 border: 1px solid var(--border2);
 border-radius: 6px;
 color: var(--text2);
 cursor: pointer;
 transition: all 0.2s;
 }

 .pager-btn:hover, .pager-btn.active {
 border-color: var(--accent);
 color: var(--accent);
 }

 .btn-refresh-all {
 font-family: 'Rajdhani', sans-serif;
 font-size: 14px;
 font-weight: 700;
 letter-spacing: 1px;
 padding: 0 20px;
 background: transparent;
 border: 1px solid var(--border2);
 border-radius: 8px;
 color: var(--text2);
 cursor: pointer;
 transition: all 0.2s;
 display: flex;
 align-items: center;
 gap: 8px;
 white-space: nowrap;
 }

 .btn-refresh-all:hover {
 border-color: var(--accent);
 color: var(--accent);
 box-shadow: var(--glow);
 }

 .btn-stop-refresh {
 font-family: 'Rajdhani', sans-serif;
 font-size: 13px;
 font-weight: 700;
 letter-spacing: 1px;
 padding: 8px 16px;
 background: rgba(255,68,68,0.1);
 border: 1px solid rgba(255,68,68,0.4);
 border-radius: 8px;
 color: #ff4444;
 cursor: pointer;
 transition: all 0.2s;
 white-space: nowrap;
 }
 .btn-stop-refresh:hover {
 background: rgba(255,68,68,0.2);
 box-shadow: 0 0 12px rgba(255,68,68,0.3);
 }

 .btn-refresh-all.spinning #refreshAllIcon {
 display: inline-block;
 animation: spin 0.8s linear infinite;
 }

 /* Wear guide */
 .wear-guide {
 display: flex;
 flex-wrap: wrap;
 align-items: center;
 gap: 8px;
 margin-top: 14px;
 padding-top: 14px;
 border-top: 1px solid var(--border);
 }

 .wear-guide-label {
 font-family: 'Share Tech Mono', monospace;
 font-size: 11px;
 color: var(--text2);
 text-transform: uppercase;
 letter-spacing: 1px;
 white-space: nowrap;
 }

 .wear-chip {
 font-size: 12px;
 color: var(--text2);
 background: var(--bg3);
 border: 1px solid var(--border);
 border-radius: 6px;
 padding: 4px 10px;
 cursor: pointer;
 transition: all 0.15s;
 white-space: nowrap;
 }

 .wear-chip b {
 color: var(--accent);
 font-weight: 600;
 }

 .wear-chip:hover {
 border-color: var(--accent);
 color: var(--text);
 background: rgba(0,212,255,0.06);
 }

 .wear-chip:active {
 transform: scale(0.97);
 }

 .btn-refresh-all:disabled {
 opacity: 0.5;
 cursor: not-allowed;
 }


 @keyframes spin {
 from { transform: rotate(0deg); }
 to { transform: rotate(360deg); }
 }

 /* Price change badges */
 .item-img-banner { position: relative; }

 .change-badge-wrap {
 position: absolute;
 top: 8px;
 right: 8px;
 }

 .price-change {
 font-family: 'Orbitron', monospace;
 font-size: 11px;
 font-weight: 700;
 padding: 4px 8px;
 border-radius: 6px;
 letter-spacing: 0.5px;
 }

 .price-change.up {
 background: rgba(57,255,20,0.15);
 border: 1px solid rgba(57,255,20,0.5);
 color: #39ff14;
 box-shadow: 0 0 10px rgba(57,255,20,0.3);
 }

 .price-change.down {
 background: rgba(255,68,68,0.15);
 border: 1px solid rgba(255,68,68,0.5);
 color: #ff4444;
 box-shadow: 0 0 10px rgba(255,68,68,0.3);
 }

 .price-change.neutral {
 background: rgba(200,200,200,0.08);
 border: 1px solid rgba(200,200,200,0.2);
 color: var(--text2);
 }

 .price-history-row {
 display: flex;
 justify-content: space-between;
 align-items: center;
 padding: 5px 0;
 border-top: 1px solid var(--border);
 margin-top: 4px;
 }

 .price-history-label {
 font-family: 'Share Tech Mono', monospace;
 font-size: 10px;
 color: var(--text2);
 text-transform: uppercase;
 letter-spacing: 1px;
 }

 .price-history-val {
 font-family: 'Share Tech Mono', monospace;
 font-size: 12px;
 color: var(--text2);
 opacity: 0.7;
 }

 /* AI Panel */
 .ai-panel {
 background: var(--bg2);
 border: 1px solid var(--border);
 border-radius: 12px;
 overflow: hidden;
 display: flex;
 flex-direction: column;
 height: 75vh;
 min-height: 500px;
 }

 .ai-header {
 display: flex;
 align-items: center;
 gap: 14px;
 padding: 16px 20px;
 border-bottom: 1px solid var(--border);
 background: linear-gradient(135deg, rgba(0,212,255,0.05), transparent);
 flex-shrink: 0;
 }

 .ai-avatar {
 font-size: 28px;
 width: 46px;
 height: 46px;
 background: var(--bg3);
