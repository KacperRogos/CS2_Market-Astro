async function takeSnapshot() {
  if (!currentUser) { showError('Snapshoty dostępne tylko po zalogowaniu'); return; }
  const btn = document.getElementById('snapshotBtn'); btn.disabled = true; btn.textContent = '⟳ Zapisuję...';
  const total = items.reduce((s, i) => s + (i.price || 0) * i.qty, 0);
  const { error } = await _sb.from('portfolio_snapshots').insert({ user_id: currentUser.id, total_value: parseFloat(total.toFixed(2)), item_count: items.length });
  btn.disabled = false; btn.textContent = 'Zapisz teraz';
  if (error) { showError('Błąd zapisu: ' + error.message); return; }
  await loadHistory(); showError('Snapshot zapisany!');
}

async function loadHistory() {
  if (!currentUser) { document.getElementById('historyEmpty').style.display = 'block'; document.getElementById('historyStats').style.display = 'none'; document.getElementById('historyTableWrap').style.display = 'none'; if (historyChart) { historyChart.destroy(); historyChart = null; } return; }
  const since = new Date(); since.setDate(since.getDate() - 90);
  const { data, error } = await _sb.from('portfolio_snapshots').select('total_value,item_count,taken_at').eq('user_id', currentUser.id).gte('taken_at', since.toISOString()).order('taken_at', { ascending: true });
  if (error) { showError('Błąd historii: ' + error.message); return; }
  historyData = data || []; renderHistory();
}

function renderHistory() {
  const cutoff = new Date(); cutoff.setDate(cutoff.getDate() - historyRange);
  const filtered = historyData.filter(r => new Date(r.taken_at) >= cutoff);
  const empty = document.getElementById('historyEmpty'), stats = document.getElementById('historyStats'), table = document.getElementById('historyTableWrap'), canvas = document.getElementById('historyChart');
  if (filtered.length === 0) { empty.style.display = 'block'; stats.style.display = 'none'; table.style.display = 'none'; canvas.style.display = 'none'; if (historyChart) { historyChart.destroy(); historyChart = null; } return; }
  empty.style.display = 'none'; canvas.style.display = 'block'; stats.style.display = 'grid'; table.style.display = 'block';
  const labels = filtered.map(r => { const d = new Date(r.taken_at); return d.toLocaleDateString('pl-PL', { day:'2-digit', month:'2-digit' }); });
  const values = filtered.map(r => parseFloat(r.total_value));
  if (historyChart) historyChart.destroy();
  historyChart = new Chart(canvas, { type:'line', data:{ labels, datasets:[{ label:'Wartość portfela (zł)', data:values, borderColor:'#00d4ff', backgroundColor:'rgba(0,212,255,0.08)', borderWidth:2.5, pointBackgroundColor:'#00d4ff', pointRadius:filtered.length<=14?5:3, pointHoverRadius:7, fill:true, tension:0.35 }] }, options:{ responsive:true, maintainAspectRatio:false, interaction:{mode:'index',intersect:false}, plugins:{ legend:{display:false}, tooltip:{backgroundColor:'#0d1318',borderColor:'#1e2d3d',borderWidth:1,titleColor:'#7a9ab8',bodyColor:'#00d4ff',callbacks:{label:ctx=>` ${ctx.parsed.y.toFixed(2).replace('.',',')} zł`}} }, scales:{ x:{grid:{color:'rgba(30,45,61,0.5)'},ticks:{color:'#7a9ab8',font:{family:'Share Tech Mono',size:11}}}, y:{grid:{color:'rgba(30,45,61,0.5)'},ticks:{color:'#7a9ab8',font:{family:'Share Tech Mono',size:11},callback:v=>v.toFixed(0)+' zł'}} } } });
  const max=Math.max(...values),min=Math.min(...values),first=values[0],last=values[values.length-1],diff=last-first,pct=first>0?(diff/first)*100:0,sign=diff>=0?'+':'−',color=diff>=0?'#39ff14':'#ff4444';
  document.getElementById('hstat-max').textContent = max.toFixed(2).replace('.',',') + ' zł';
  document.getElementById('hstat-min').textContent = min.toFixed(2).replace('.',',') + ' zł';
  document.getElementById('hstat-count').textContent = filtered.length;
  const changeEl = document.getElementById('hstat-change'); changeEl.style.color = color;
  changeEl.textContent = `${sign}${Math.abs(diff).toFixed(2).replace('.',',')} zł (${sign}${Math.abs(pct).toFixed(1)}%)`;
  const tbody = document.getElementById('historyTableBody');
  const rows = [...filtered].reverse();
  tbody.innerHTML = rows.map((r, i) => {
    const prev = rows[i + 1]; const val = parseFloat(r.total_value); const d = new Date(r.taken_at);
    const dateStr = d.toLocaleDateString('pl-PL',{day:'2-digit',month:'2-digit',year:'numeric'})+' '+d.toLocaleTimeString('pl-PL',{hour:'2-digit',minute:'2-digit'});
    let changeHtml = '<span style="color:var(--text2)">—</span>';
    if (prev) { const prevVal = parseFloat(prev.total_value); const chg = val - prevVal; const cls = chg>0?'color:#39ff14':chg<0?'color:#ff4444':'color:var(--text2)'; const s = chg>=0?'+':'−'; changeHtml = `<span style="${cls}">${s}${Math.abs(chg).toFixed(2).replace('.',',')} zł</span>`; }
    return `<tr><td style="font-family:'Share Tech Mono',monospace;font-size:13px;color:var(--text2)">${dateStr}</td><td style="font-family:'Orbitron',monospace;font-weight:700;color:var(--accent)">${val.toFixed(2).replace('.',',')} zł</td><td style="color:var(--text2)">${r.item_count}</td><td>${changeHtml}</td></tr>`;
  }).join('');
}

async function autoSnapshot() {
  if (!currentUser) return;
  const key = 'last_snapshot_' + currentUser.id;
  const last = localStorage.getItem(key); const now = Date.now();
  if (last && now - parseInt(last) < 6*60*60*1000) return;
  const total = items.reduce((s, i) => s + (i.price || 0) * i.qty, 0);
  if (total <= 0) return;
  try { await _sb.from('portfolio_snapshots').insert({ user_id: currentUser.id, total_value: parseFloat(total.toFixed(2)), item_count: items.length }); localStorage.setItem(key, now.toString()); } catch(e) {}
}

// ── SEARCH ────────────────────────────────────────────────────
let searchPage = 0, searchQuery = '', searchTotal = 0, searchResultsCache = [];
const PAGE_SIZE = 20;

async function doSearch(page = 0) {
  const query = document.getElementById('searchInput').value.trim(); if (!query) return;
  searchQuery = query; searchPage = page;
  const sort = document.getElementById('searchSort').value;
  const start = page * PAGE_SIZE;
  document.getElementById('searchResults').innerHTML = '<div class="search-loading">Szukam na Steam Market...</div>';
  document.getElementById('searchPager').innerHTML = '';
  searchResultsCache = [];
  const sortParam = sort==='price_asc'?'&sort_column=price&sort_dir=asc':sort==='price_desc'?'&sort_column=price&sort_dir=desc':sort==='name'?'&sort_column=name&sort_dir=asc':'&sort_column=popular&sort_dir=desc';
  try {
    const url = `https://steamcommunity.com/market/search/render/?appid=730&norender=1&search_descriptions=0&query=${encodeURIComponent(query)}&start=${start}&count=${PAGE_SIZE}&currency=6${sortParam}`;
    const data = await steamFetch(url);
    if (!data.success || !data.results || data.results.length === 0) { document.getElementById('searchResults').innerHTML = '<div class="search-empty">Brak wyników dla: <strong>' + escapeHtml(query) + '</strong></div>'; return; }
    searchTotal = data.total_count || data.results.length;
    await renderSearchResults(data.results); renderPager();
  } catch(e) { document.getElementById('searchResults').innerHTML = `<div class="search-empty">Błąd: ${escapeHtml(e.message)}</div>`; }
}

async function renderSearchResults(results) {
  const grid = document.getElementById('searchResults'); searchResultsCache = [];
  grid.innerHTML = results.map(r => {
    const iconUrl = r.asset_description?.icon_url || '';
    const imgSrc = iconUrl ? `https://community.cloudflare.steamstatic.com/economy/image/${iconUrl}/200fx125f` : '';
    const cents = r.sell_price || 0; const priceNum = parseFloat(((cents/100)*STEAM_USD_PLN).toFixed(2));
    const priceDisplay = cents > 0 ? priceNum.toFixed(2).replace('.',',') + ' zł' : '—';
    const name = r.name || ''; const inPortfolio = items.some(i => i.name === name);
    const dataIdx = searchResultsCache.length;
    searchResultsCache.push({ name, priceRaw: priceDisplay, priceNum, iconUrl });
    return `<div class="search-card">
      ${imgSrc ? `<img class="search-card-img" src="${imgSrc}" onerror="this.style.opacity=0.2" loading="lazy">` : '<div class="search-card-img" style="opacity:0.1"></div>'}
      <div class="search-card-name" title="${escapeHtml(name)}">${escapeHtml(name)}</div>
      <div class="search-card-price">${escapeHtml(priceDisplay)}</div>
      <div class="search-card-add ${inPortfolio ? 'added' : ''}" onclick="addFromSearch(${dataIdx},this)">${inPortfolio ? 'W portfelu' : '+ Dodaj do portfela'}</div>
    </div>`;
  }).join('');
}

async function addFromSearch(idx, btn) {
  const r = searchResultsCache[idx]; if (!r) return;
  const { name, priceRaw, priceNum, iconUrl } = r;
  const exists = items.find(i => i.name === name);
  if (exists) { exists.qty += 1; if (iconUrl && !exists.iconUrl) exists.iconUrl = iconUrl; saveItems(); renderItems(); btn.textContent = 'W portfelu'; btn.className = 'search-card-add added'; return; }
  items.push({ id: Date.now(), name, qty: 1, price: priceNum > 0 ? priceNum : null, priceRaw: priceNum > 0 ? priceRaw : null, iconUrl, loading: false });
  saveItems(); renderItems(); btn.textContent = 'W portfelu'; btn.className = 'search-card-add added';
}

function renderPager() {
  const pager = document.getElementById('searchPager'); const totalPages = Math.ceil(searchTotal / PAGE_SIZE); if (totalPages <= 1) return;
  const pages = []; for (let i = 0; i < totalPages && i < 7; i++) pages.push(i);
  pager.innerHTML = [searchPage > 0 ? `<button class="pager-btn" onclick="doSearch(${searchPage-1})">← Poprzednia</button>` : '', ...pages.map(p => `<button class="pager-btn ${p===searchPage?'active':''}" onclick="doSearch(${p})">${p+1}</button>`), searchPage < totalPages-1 ? `<button class="pager-btn" onclick="doSearch(${searchPage+1})">Następna →</button>` : ''].join('');
}

