const DEMO_EMAIL = 'demo@cs2-market.app';
const DEMO_PASSWORD = 'CS2Demo2026!';

async function loadGuestItemsBatch() {
  // Ciche odświeżenie w tle — dane startowe (wpisane na sztywno w GUEST_DEFAULT_ITEMS)
  // już są widoczne, więc NIE pokazujemy stanu ładowania. Jeśli się uda — ceny/obrazki
  // się zaktualizują; jeśli nie — nic się nie zmienia, użytkownik i tak widzi dobre dane.
  await Promise.all(items.map(async (item) => {
    const result = await fetchPrice(item.name);
    if (result) { updateItemPrice(item, result); if (result.iconUrl) item.iconUrl = result.iconUrl; }
  }));
  saveItems(); renderItems();
}

async function loginAsGuest() {
  const guestBtn = document.querySelector('.btn-guest');
  if (guestBtn) { guestBtn.disabled = true; guestBtn.textContent = 'Logowanie...'; }

  try {
    // Gość to teraz prawdziwe, stałe konto w bazie — przechodzi dokładnie tę samą
    // ścieżkę co zwykły użytkownik (te same zapisy/odczyty z Supabase), zamiast
    // osobnej, uproszczonej logiki opartej tylko o localStorage.
    const { data, error } = await _sb.auth.signInWithPassword({ email: DEMO_EMAIL, password: DEMO_PASSWORD });
    if (error) throw error;
    currentUser = data.user;

    // Przy KAŻDYM wejściu w tryb demo resetuj portfolio do tych samych 5 przedmiotów —
    // z wpisanymi na sztywno cenami/obrazkami, więc widać je NATYCHMIAST i ZAWSZE,
    // niezależnie od tego czy Steam akurat odpowiada, czy nie.
    items = GUEST_DEFAULT_ITEMS.map((g, idx) => ({
      id: Date.now() + idx, name: g.name, qty: g.qty,
      price: g.price, priceRaw: g.priceRaw, iconUrl: g.iconUrl, loading: false,
    }));
    localStorage.setItem('cs2_items', JSON.stringify(items));
    await _sb.from('portfolios').upsert({ user_id: currentUser.id, items, updated_at: new Date().toISOString() }, { onConflict: 'user_id' });

    document.getElementById('headerUsername').textContent = 'Gość (demo)';
    document.getElementById('authScreen').style.display = 'none';
    renderItems();
    // Próba dyskretnego odświeżenia cen w tle — czysto "best effort", NIE blokuje
    // wyświetlenia i niczego nie psuje jeśli się nie uda (dane startowe już są widoczne).
    setTimeout(() => loadGuestItemsBatch(), 1500);
  } catch (e) {
    showAuthError('Nie udało się uruchomić trybu demo. Spróbuj ponownie za chwilę.');
  } finally {
    if (guestBtn) { guestBtn.disabled = false; guestBtn.textContent = 'Zaloguj jako gość'; }
  }
}

async function saveToSupabase() {
  if (!currentUser) return;
  try { await _sb.from('portfolios').upsert({ user_id: currentUser.id, items, updated_at: new Date().toISOString() }, { onConflict: 'user_id' }); } catch(e) {}
}

(async () => {
  const isPublic = await checkPublicPortfolio();
  if (isPublic) return;
  const { data: { session } } = await _sb.auth.getSession();
  if (session) {
    if (session.user.email === DEMO_EMAIL) {
      // Sesja demo NIE powinna się sama przywracać po odświeżeniu/przejściu na inną
