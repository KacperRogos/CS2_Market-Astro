 }
  /* ── AUTH SCREEN ─────────────────────────────────────── */
  #authScreen {
    position: fixed;
    inset: 0;
    background: var(--bg);
    z-index: 1000;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 20px;
  }

  .auth-box {
    background: var(--bg2);
    border: 1px solid var(--border2);
    border-radius: 16px;
    padding: 36px 32px;
    width: 100%;
    max-width: 400px;
    box-shadow: 0 24px 64px rgba(0,0,0,0.6);
  }

  .auth-logo {
    text-align: center;
    margin-bottom: 28px;
  }

  .auth-logo h1 {
    font-family: 'Orbitron', monospace;
    font-size: 22px;
    font-weight: 900;
    color: #fff;
    letter-spacing: 2px;
  }

  .auth-logo h1 span { color: var(--accent); }
  .auth-logo p { font-size: 13px; color: var(--text2); margin-top: 4px; }

  .auth-tabs {
    display: flex;
    gap: 4px;
    background: var(--bg3);
    border-radius: 8px;
    padding: 4px;
    margin-bottom: 24px;
  }

  .auth-tab {
    flex: 1;
    font-family: 'Rajdhani', sans-serif;
    font-size: 14px;
    font-weight: 700;
    letter-spacing: 1px;
    padding: 8px;
    border: none;
    border-radius: 6px;
    background: transparent;
    color: var(--text2);
    cursor: pointer;
    transition: all 0.2s;
  }

  .auth-tab.active {
    background: var(--bg2);
    color: var(--accent);
    border: 1px solid var(--border2);
  }

  .auth-field {
    margin-bottom: 14px;
  }

  .auth-field label {
    display: block;
    font-family: 'Share Tech Mono', monospace;
    font-size: 11px;
    color: var(--text2);
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 6px;
  }

  .auth-field input {
    width: 100%;
    background: var(--bg3);
    border: 1px solid var(--border2);
    border-radius: 8px;
    padding: 10px 14px;
    font-family: 'Rajdhani', sans-serif;
    font-size: 15px;
    color: var(--text);
    outline: none;
    transition: border-color 0.2s;
    box-sizing: border-box;
  }

  .auth-field input:focus {
    border-color: var(--accent);
    box-shadow: var(--glow);
  }

  .auth-btn {
    width: 100%;
    font-family: 'Rajdhani', sans-serif;
    font-size: 15px;
    font-weight: 700;
    letter-spacing: 2px;
    padding: 12px;
    background: linear-gradient(135deg, var(--accent), #0088cc);
    border: none;
    border-radius: 8px;
    color: #000;
    cursor: pointer;
    transition: all 0.2s;
    margin-top: 8px;
  }

  .auth-btn:hover { box-shadow: var(--glow); transform: translateY(-1px); }
  .auth-btn:disabled { opacity: 0.5; cursor: not-allowed; transform: none; }

  .auth-error {
    background: rgba(255,68,68,0.1);
    border: 1px solid rgba(255,68,68,0.3);
    border-radius: 8px;
    padding: 10px 14px;
    font-size: 13px;
    color: #ff6b6b;
    margin-top: 12px;
    display: none;
  }

  .auth-success {
    background: rgba(57,255,20,0.08);
    border: 1px solid rgba(57,255,20,0.2);
    border-radius: 8px;
    padding: 10px 14px;
    font-size: 13px;
    color: #39ff14;
    margin-top: 12px;
    display: none;
  }

  /* User info w headerze */
  .user-info {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .user-name {
    font-family: 'Share Tech Mono', monospace;
    font-size: 11px;
    color: var(--text2);
    letter-spacing: 0.5px;
  }

  .btn-logout {
    font-family: 'Rajdhani', sans-serif;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 1px;
    text-transform: uppercase;
    padding: 6px 14px;
    background: transparent;
    border: 1px solid rgba(255,68,68,0.35);
    border-radius: 6px;
    color: rgba(255,100,100,0.7);
    cursor: pointer;
    transition: background 0.2s, border-color 0.2s, color 0.2s, transform 0.15s, box-shadow 0.2s;
    white-space: nowrap;
  }

  .btn-logout:hover {
    background: rgba(255,68,68,0.1);
    border-color: #ff4444;
    color: #ff6666;
    transform: translateY(-1px);
    box-shadow: 0 4px 12px rgba(255,68,68,0.2);
  }

  .btn-logout:active { transform: scale(0.95); }

  /* ── MOBILE ───────────────────────────────────────────── */
  @media (max-width: 600px) {

    /* Header */
    .header-inner {
      flex-direction: column;
      align-items: flex-start;
      gap: 8px;
      padding: 10px 0;
    }

    .header-center {
      width: 100%;
      justify-content: flex-start;
      flex-wrap: wrap;
      gap: 6px;
    }

    .header-right {
      width: 100%;
      border-left: none;
      border-top: 1px solid var(--border);
      padding-left: 0;
      padding-top: 8px;
      margin-left: 0;
      justify-content: flex-end;
    }

    .total-value {
      flex: 1;
      min-width: 160px;
      padding: 8px 12px;
    }

    .total-amount { font-size: 22px; }

    .btn-import-header,
    .btn-portfolio-save,
    .btn-portfolio-load {
      font-size: 12px;
      padding: 6px 10px;
    }

    /* Tabs — zastąpione na mobile przez dropdown (.tabs-mobile poniżej) */
    .tabs {
      display: none !important;
    }
    .tabs-mobile {
      display: block;
    }

    /* Add form */
    .add-form {
      flex-direction: column;
    }

    .add-form .input-group,
    .add-form .input-small {
      flex: none;
      width: 100%;
    }

    /* Stats bar */
    .stats-bar {
      flex-wrap: wrap;
      gap: 8px;
    }

    .stat-card {
      flex: 1;
      min-width: 80px;
      padding: 8px 12px;
    }

    .stat-value { font-size: 16px; }

    .btn-refresh-all,
    .btn-stop-refresh {
      font-size: 12px;
      padding: 8px 12px;
    }

    /* Filter bar */
    .filter-btn {
      font-size: 12px;
      padding: 5px 10px;
    }

    /* Items grid — 1 kolumna na małych, 2 na większych */
    .items-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 10px;
    }

    .item-img-banner { height: 90px; }
    .item-skin { font-size: 12px; }
    .item-weapon { font-size: 10px; }
    .item-price-total { font-size: 14px; }
    .item-price-single { font-size: 11px; }

    /* Search results */
    .search-results-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 10px;
    }

    /* AI panel */
    .ai-panel { height: 65vh; }
    .ai-suggestions { gap: 6px; }
    .ai-chip { font-size: 11px; padding: 4px 8px; }

    /* Import modal */
    .import-modal-box {
      padding: 18px;
      max-width: 100%;
      margin: 10px;
    }

    /* Wear guide */
    .wear-guide { gap: 6px; }
    .wear-chip { font-size: 11px; padding: 3px 8px; }

    /* Container padding */
    .container { padding: 0 12px; }
  }

  /* Bardzo małe telefony */
  @media (max-width: 380px) {
    .items-grid { grid-template-columns: 1fr; }
    .search-results-grid { grid-template-columns: 1fr; }
  }


/* ── HISTORIA ───────────────────────────────────────────── */
.history-header {
 display: flex;
 align-items: flex-start;
 justify-content: space-between;
 gap: 16px;
 flex-wrap: wrap;
 margin-bottom: 4px;
}

.history-range-bar {
 display: flex;
 gap: 8px;
 margin-bottom: 20px;
 flex-wrap: wrap;
}

.history-chart-wrap {
 position: relative;
 background: var(--bg2);
 border: 1px solid var(--border);
 border-radius: 16px;
 padding: 24px;
 margin-bottom: 20px;
 min-height: 280px;
 display: flex;
 align-items: center;
 justify-content: center;
}

.history-chart-wrap canvas {
 width: 100% !important;
 max-height: 280px;
}

.history-empty {
 text-align: center;
 padding: 40px;
}

.history-stats-row {
 display: grid;
 grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
 gap: 12px;
 margin-bottom: 24px;
}

.history-stat-card {
 background: var(--bg2);
 border: 1px solid var(--border);
 border-radius: 12px;
 padding: 16px 20px;
 display: flex;
 flex-direction: column;
 gap: 6px;
}

.history-stat-label {
 font-size: 11px;
 text-transform: uppercase;
 letter-spacing: 0.08em;
 color: var(--text2);
 font-family: 'Share Tech Mono', monospace;
}

.history-stat-value {
 font-family: 'Orbitron', monospace;
 font-size: 18px;
 font-weight: 700;
 color: var(--text);
}

.history-table-wrap {
 background: var(--bg2);
 border: 1px solid var(--border);
 border-radius: 16px;
 padding: 20px 24px;
 overflow-x: auto;
}

.history-table {
 width: 100%;
 border-collapse: collapse;
 font-size: 14px;
}

.history-table th {
 text-align: left;
 padding: 8px 16px;
 font-family: 'Share Tech Mono', monospace;
 font-size: 11px;
 text-transform: uppercase;
 letter-spacing: 0.08em;
 color: var(--text2);
 border-bottom: 1px solid var(--border);
}

.history-table td {
 padding: 12px 16px;
 border-bottom: 1px solid rgba(30,45,61,0.5);
 color: var(--text);
 font-family: 'Rajdhani', sans-serif;
 font-size: 15px;
}

.history-table tr:last-child td { border-bottom: none; }

.history-table tr:hover td {
 background: rgba(0,212,255,0.03);
}

.history-change-up   { color: #39ff14; font-weight: 700; }
.history-change-down { color: #ff4444; font-weight: 700; }
.history-change-neu  { color: var(--text2); }

/* ── STOPKA ─────────────────────────────────────────────────── */
.site-footer {
 margin-top: 64px;
 border-top: 1px solid var(--border);
 background: linear-gradient(180deg, transparent 0%, rgba(0,212,255,0.03) 100%);
 padding: 28px 0 24px;
}

.footer-inner {
 display: flex;
 align-items: center;
 justify-content: space-between;
 gap: 24px;
 flex-wrap: wrap;
}

.footer-author {
 display: flex;
 align-items: center;
 gap: 10px;
}

.footer-made {
 font-size: 11px;
 color: var(--text2);
 text-transform: uppercase;
 letter-spacing: 0.08em;
 font-family: 'Share Tech Mono', monospace;
}

.footer-name {
 font-family: 'Orbitron', monospace;
 font-size: 13px;
 font-weight: 700;
 color: var(--accent);
 text-decoration: none;
 transition: color 0.2s, text-shadow 0.2s;
}

.footer-name:hover {
 color: #fff;
 text-shadow: 0 0 12px rgba(0,212,255,0.7);
}

.footer-copy {
 font-family: 'Share Tech Mono', monospace;
 font-size: 11px;
 color: var(--text2);
 opacity: 0.6;
 text-align: center;
}

.footer-contact-wrap {
 position: relative;
}

.footer-contact-btn {
 font-family: 'Rajdhani', sans-serif;
 font-size: 14px;
 font-weight: 700;
 letter-spacing: 1px;
 text-transform: uppercase;
 padding: 9px 20px;
 background: transparent;
 border: 1px solid var(--border2);
 border-radius: 8px;
 color: var(--text2);
 cursor: pointer;
 transition: all 0.2s;
}

.footer-contact-btn:hover {
 border-color: var(--accent);
 color: var(--accent);
 box-shadow: 0 0 12px rgba(0,212,255,0.15);
}

/* Formularz kontaktowy — popup nad przyciskiem */
.footer-form-box {
 position: absolute;
 bottom: calc(100% + 12px);
 right: 0;
 width: 320px;
 background: var(--bg2);
 border: 1px solid var(--border2);
 border-radius: 14px;
 padding: 20px;
 box-shadow: 0 -8px 40px rgba(0,0,0,0.5), 0 0 0 1px rgba(0,212,255,0.08);
 z-index: 200;
 animation: fadeInUp 0.2s ease;
}

@keyframes fadeInUp {
 from { opacity: 0; transform: translateY(8px); }
 to   { opacity: 1; transform: translateY(0); }
}

.footer-form-header {
 display: flex;
 align-items: center;
 justify-content: space-between;
 margin-bottom: 16px;
 font-family: 'Orbitron', monospace;
 font-size: 13px;
 font-weight: 700;
 color: var(--accent);
}

.footer-form-close {
 background: none;
 border: none;
 color: var(--text2);
 font-size: 16px;
 cursor: pointer;
 padding: 2px 6px;
 border-radius: 4px;
 transition: color 0.2s;
}

.footer-form-close:hover { color: #fff; }

.footer-field {
 display: flex;
 flex-direction: column;
 gap: 5px;
 margin-bottom: 12px;
}

.footer-field label {
 font-family: 'Share Tech Mono', monospace;
 font-size: 11px;
 text-transform: uppercase;
 letter-spacing: 0.08em;
 color: var(--text2);
}

.footer-field input,
.footer-field textarea {
 background: var(--bg3);
 border: 1px solid var(--border);
 border-radius: 8px;
 padding: 9px 12px;
 font-family: 'Rajdhani', sans-serif;
 font-size: 14px;
 color: var(--text);
 outline: none;
 transition: border-color 0.2s;
 resize: none;
 width: 100%;
}

.footer-field input:focus,
.footer-field textarea:focus {
 border-color: var(--accent);
}

/* Checkbox anonimowy */
.footer-anon-label {
 display: flex;
 align-items: center;
 gap: 9px;
 cursor: pointer;
 margin-bottom: 14px;
 font-family: 'Rajdhani', sans-serif;
 font-size: 13px;
 color: var(--text2);
 user-select: none;
}

.footer-anon-label input[type="checkbox"] { display: none; }

.footer-anon-check {
 width: 18px;
 height: 18px;
 border: 1px solid var(--border2);
 border-radius: 4px;
 background: var(--bg3);
 display: flex;
 align-items: center;
 justify-content: center;
 flex-shrink: 0;
 transition: all 0.15s;
}

.footer-anon-label input:checked + .footer-anon-check {
 background: var(--accent);
 border-color: var(--accent);
}

.footer-anon-label input:checked + .footer-anon-check::after {
 content: '✓';
 font-size: 12px;
 color: #000;
 font-weight: 700;
}

.footer-submit-btn {
 width: 100%;
 padding: 11px;
 background: linear-gradient(135deg, var(--accent), #0066ff);
 border: none;
 border-radius: 8px;
 color: #000;
 font-family: 'Orbitron', monospace;
 font-size: 12px;
 font-weight: 700;
 letter-spacing: 1px;
 cursor: pointer;
 transition: opacity 0.2s, transform 0.1s;
}

.footer-submit-btn:hover { opacity: 0.9; }
.footer-submit-btn:active { transform: scale(0.98); }
.footer-submit-btn:disabled { opacity: 0.5; cursor: not-allowed; }

#contactStatus {
 margin-top: 10px;
 padding: 8px 12px;
 border-radius: 7px;
 font-family: 'Rajdhani', sans-serif;
 font-size: 13px;
 text-align: center;
}

#contactStatus.ok  { background: rgba(57,255,20,0.1); color: #39ff14; border: 1px solid rgba(57,255,20,0.3); }
#contactStatus.err { background: rgba(255,68,68,0.1); color: #ff6b6b; border: 1px solid rgba(255,68,68,0.3); }

@media (max-width: 600px) {
 .footer-inner { flex-direction: column; align-items: flex-start; gap: 16px; }
 .footer-copy  { text-align: left; }
 .footer-form-box { right: auto; left: 0; width: 290px; }
}

/* ── PUBLICZNE PORTFELE ─────────────────────────────────── */
.btn-share-portfolio {
 background: linear-gradient(135deg, rgba(0,212,255,0.15), rgba(0,212,255,0.05));
 border: 1px solid rgba(0,212,255,0.4);
 color: var(--accent);
 border-radius: 10px;
 padding: 8px 16px;
 font-family: 'Orbitron', monospace;
 font-size: 11px;
 font-weight: 700;
 cursor: pointer;
 letter-spacing: 0.05em;
 transition: all 0.2s;
 white-space: nowrap;
}

.btn-share-portfolio:hover {
 background: rgba(0,212,255,0.2);
 border-color: var(--accent);
 box-shadow: 0 0 12px rgba(0,212,255,0.3);
}

/* Toggle switch */
.share-toggle {
 position: relative;
 display: inline-block;
 width: 48px;
 height: 26px;
 flex-shrink: 0;
}

.share-toggle input { opacity: 0; width: 0; height: 0; }

.share-toggle-slider {
 position: absolute;
 inset: 0;
 background: rgba(255,255,255,0.1);
 border: 1px solid var(--border2);
 border-radius: 26px;
 cursor: pointer;
 transition: 0.3s;
}

.share-toggle-slider::before {
 content: '';
 position: absolute;
 left: 3px;
 top: 50%;
 transform: translateY(-50%);
 width: 18px;
 height: 18px;
 background: var(--text2);
 border-radius: 50%;
 transition: 0.3s;
}

.share-toggle input:checked + .share-toggle-slider {
 background: rgba(0,212,255,0.2);
 border-color: var(--accent);
}

.share-toggle input:checked + .share-toggle-slider::before {
 transform: translate(22px, -50%);
 background: var(--accent);
}

/* Publiczny portfel — responsywny grid dopasowany do okna */
#pubItemsGrid {
 grid-template-columns: repeat(auto-fill, minmax(min(220px, 100%), 1fr));
}

/* ── EMAIL PREFIX w rejestracji ─────────────────────────── */
.auth-email-wrap {
 display: flex;
 align-items: center;
 background: var(--bg3, #0f172a);
 border: 1px solid rgba(255,255,255,0.08);
 border-radius: 8px;
 overflow: hidden;
 transition: border-color 0.2s;
}

.auth-email-wrap:focus-within {
 border-color: var(--accent);
 box-shadow: 0 0 0 2px rgba(0,212,255,0.1);
}

.auth-email-wrap input {
 flex: 1;
 background: transparent;
 border: none !important;
 box-shadow: none !important;
 border-radius: 0 !important;
 padding: 10px 12px;
 color: var(--text);
 font-size: 14px;
 outline: none;
}

.auth-email-domain {
 padding: 0 12px;
 font-family: 'Share Tech Mono', monospace;
 font-size: 12px;
 color: var(--accent);
 opacity: 0.7;
 white-space: nowrap;
 border-left: 1px solid rgba(255,255,255,0.06);
 line-height: 40px;
}

.auth-email-preview {
 margin-top: 5px;
 font-family: 'Share Tech Mono', monospace;
 font-size: 11px;
 color: var(--text2);
 opacity: 0.8;
}

.auth-email-preview span {
 color: var(--accent);
}

/* ── PUBLIC PORTFOLIO HEADER CARD ──────────────────────── */
.pub-header-card {
 display: flex;
 align-items: center;
 justify-content: space-between;
 gap: 16px;
 background: var(--bg2);
 border: 1px solid var(--border2);
 border-radius: 16px;
 padding: 20px 24px;
 margin-bottom: 24px;
 flex-wrap: wrap;
}

.pub-header-left {
 display: flex;
 flex-direction: column;
 gap: 4px;
}

.pub-header-label {
 font-size: 11px;
 color: var(--text2);
 font-family: 'Share Tech Mono', monospace;
 letter-spacing: 0.1em;
 text-transform: uppercase;
}

.pub-header-value {
 font-family: 'Orbitron', monospace;
 font-size: 28px;
 font-weight: 900;
 color: var(--accent);
 line-height: 1.1;
}

.pub-header-sub {
 font-size: 13px;
 color: var(--text2);
 margin-top: 2px;
}

.pub-header-right {
 display: flex;
 flex-direction: column;
 align-items: center;
 gap: 6px;
 text-align: center;
}

.pub-avatar {
 width: 48px;
 height: 48px;
 border-radius: 50%;
 background: linear-gradient(135deg, var(--accent), #0066ff);
 display: flex;
 align-items: center;
 justify-content: center;
 font-size: 22px;
 box-shadow: 0 0 16px rgba(0,212,255,0.3);
}

.pub-username {
 font-family: 'Orbitron', monospace;
 font-size: 15px;
 font-weight: 700;
 color: var(--text);
 letter-spacing: 0.03em;
}

.pub-username-label {
 font-family: 'Share Tech Mono', monospace;
 font-size: 10px;
 color: var(--text2);
 text-transform: uppercase;
 letter-spacing: 0.08em;
 opacity: 0.7;
}

@media (max-width: 480px) {
 .pub-header-card { flex-direction: column; align-items: flex-start; }
 .pub-header-right { flex-direction: row; align-items: center; gap: 10px; }
 .pub-header-value { font-size: 22px; }
}

/* ── KOMPAKTOWY TOOLBAR ─────────────────────────────────── */
.toolbar {
 display: flex;
 align-items: center;
 gap: 12px;
 background: var(--bg2);
 border: 1px solid var(--border);
 border-radius: 14px;
 padding: 10px 16px;
 margin-bottom: 16px;
 flex-wrap: wrap;
}

.toolbar-stats {
 display: flex;
 align-items: center;
 gap: 8px;
 flex: 1;
 min-width: 0;
 flex-wrap: wrap;
}

.stat-pill {
 display: flex;
 align-items: baseline;
 gap: 5px;
 background: var(--bg3);
 border: 1px solid var(--border);
 border-radius: 8px;
 padding: 5px 10px;
 white-space: nowrap;
}

.stat-pill-label {
 font-family: 'Share Tech Mono', monospace;
 font-size: 10px;
 color: var(--text2);
 text-transform: uppercase;
 letter-spacing: 0.05em;
}

.stat-pill-value {
 font-family: 'Orbitron', monospace;
 font-size: 14px;
 font-weight: 700;
 color: var(--text);
}

.stat-pill-top .stat-pill-value {
 font-size: 12px;
 color: var(--accent);
 max-width: 160px;
 overflow: hidden;
 text-overflow: ellipsis;
}

.toolbar-filters {
 display: flex;
 gap: 8px;
 align-items: center;
}

.toolbar-actions {
 display: flex;
 gap: 8px;
 align-items: center;
 flex-shrink: 0;
}

@media (max-width: 768px) {
 .toolbar { gap: 8px; padding: 10px 12px; }
 .stat-pill-top { display: none; }
 .toolbar-filters, .toolbar-actions { width: 100%; }
 .toolbar-filters select { flex: 1; }
}

@media (max-width: 480px) {
 .toolbar-stats { width: 100%; }
}

/* ── FILTER SELECT ──────────────────────────────────────── */
.filter-select {
 background: var(--bg3);
 border: 1px solid var(--border2);
 border-radius: 8px;
 padding: 7px 12px;
 font-family: 'Rajdhani', sans-serif;
 font-size: 14px;
 font-weight: 600;
 color: var(--text);
 outline: none;
 cursor: pointer;
 transition: border-color 0.2s;
