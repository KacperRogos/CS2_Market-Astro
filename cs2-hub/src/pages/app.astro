// ── PUBLIC PORTFOLIO ──────────────────────────────────────────
let pubAllItems=[], pubSort='default', pubCategory='all';

function setPubSort(sort) {
  pubSort=sort; ['default','price_desc','price_asc','name'].forEach(s=>{const btn=document.getElementById('pub-sort-'+s);if(btn)btn.className='filter-btn'+(s===sort?' active':'');});
  renderPubGrid();
}
function setPubCategory(cat) {
  pubCategory=cat; ['all','weapon','knife','gloves','case','other'].forEach(c=>{const btn=document.getElementById('pub-cat-'+c);if(btn)btn.className='filter-btn'+(c===cat?' active':'');});
  renderPubGrid();
}
function renderPubGrid() {
  let filtered=[...pubAllItems];
  if(pubCategory!=='all') filtered=filtered.filter(item=>{const cat=getItemCategory(item.name);return pubCategory==='other'?!['weapon','knife','gloves','case','capsule','sticker'].includes(cat):cat===pubCategory;});
  if(pubSort==='price_desc') filtered.sort((a,b)=>(b.price||0)-(a.price||0));
  else if(pubSort==='price_asc') filtered.sort((a,b)=>(a.price||0)-(b.price||0));
  else if(pubSort==='name') filtered.sort((a,b)=>a.name.localeCompare(b.name));
  document.getElementById('pubItemsGrid').innerHTML=filtered.length===0?'<div style="text-align:center;padding:40px;color:var(--text2)">Brak przedmiotów w tej kategorii</div>':filtered.map(item=>buildPubCard(item)).join('');
}
function buildPubCard(item) {
  const imgSrc=item.iconUrl?(item.iconUrl.startsWith('http')?item.iconUrl:`https://community.cloudflare.steamstatic.com/economy/image/${item.iconUrl}/360fx230f`):'';
  const weaponName=item.name.includes('|')?item.name.split('|')[0].trim():item.name;
  const skinName=item.name.includes('|')?item.name.split('|')[1].replace(/\(.*\)/,'').trim():'';
  const wear=getWearTag(item.name);
  return `<div class="item-card" style="animation:none">
    <div class="item-img-banner">${imgSrc?`<img src="${imgSrc}" onerror="this.style.display='none'" alt="${escapeHtml(item.name)}">`:'<div class="img-placeholder-big"></div>'}</div>
    <div class="item-body"><div class="item-weapon">${escapeHtml(weaponName)}</div><div class="item-skin">${escapeHtml(skinName)}</div><div style="display:flex;align-items:center;gap:8px;margin-top:6px">${wear?`<div class="item-wear">${wear}</div>`:''}${item.qty>1?`<div style="font-size:12px;color:var(--text2);font-family:'Share Tech Mono',monospace">x${item.qty}</div>`:''}</div></div>
    <div class="item-price-row"><div class="item-price-single">${item.price?`${item.price.toFixed(2).replace('.',',')} zł / szt.`:'<span style="color:#ff6b6b;font-size:12px">brak ceny</span>'}</div><div class="item-price-total">${item.price?(item.price*(item.qty||1)).toFixed(2).replace('.',',')+' zł':''}</div></div>
  </div>`;
}

async function checkPublicPortfolio() {
  const params=new URLSearchParams(location.search); const publicId=params.get('p'); if(!publicId)return false;
  document.getElementById('authScreen').style.display='none';
  const view=document.getElementById('publicPortfolioView'); view.style.display='block';
  document.getElementById('pubItemsGrid').innerHTML='<div style="text-align:center;padding:40px;color:var(--text2)">Ładowanie portfela...</div>';
  const {data,error}=await _sb.from('portfolios').select('items,user_id').eq('public_id',publicId).eq('is_public',true).single();
  if(error||!data){document.getElementById('pubItemsGrid').innerHTML='<div style="text-align:center;padding:40px;color:#ff6b6b">Portfel nie istnieje lub jest prywatny</div>';return true;}
  let username=null;
  if(data.user_id){const{data:profile}=await _sb.from('profiles').select('username').eq('id',data.user_id).single();username=profile?.username||null;}
  pubAllItems=data.items||[];
  const total=pubAllItems.reduce((s,i)=>s+(i.price||0)*(i.qty||1),0);
  const count=pubAllItems.reduce((s,i)=>s+(i.qty||1),0);
  document.getElementById('pubTotalValue').textContent=total.toFixed(2).replace('.',',')+' zł';
  document.getElementById('pubItemCount').textContent=`${pubAllItems.length} przedmiotów · ${count} szt. łącznie`;
  document.getElementById('pubUsername').textContent=username?`@${username}`:'';
  document.getElementById('pubUsernameWrap').style.display=username?'flex':'none';
  renderPubGrid(); return true;
}

setInterval(async()=>{
  if(document.getElementById('stopRefreshBtn')?.style.display!=='none')return;
  for(const item of items){if(!item.loading){const result=await fetchPrice(item.name);if(result){updateItemPrice(item,result);if(result.iconUrl)item.iconUrl=result.iconUrl;}await new Promise(r=>setTimeout(r,1000));}}
  saveItems();renderItems();
},5*60*1000);
</script>


