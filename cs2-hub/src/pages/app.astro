<script is:inline>
function toggleContactForm() {
  const box = document.getElementById('contactFormBox');
  box.style.display = box.style.display === 'none' ? 'block' : 'none';
}
function toggleAnon(cb) {
  const nameWrap = document.getElementById('contactNameWrap');
  if (nameWrap) nameWrap.style.display = cb.checked ? 'none' : '';
}
async function handleContact(e) {
  e.preventDefault();
  const form = e.target;
  const status = document.getElementById('contactStatus');
  status.style.display = 'block';
  status.textContent = 'Wysyłanie...';
  status.style.color = 'var(--accent)';
  try {
    const res = await fetch(form.action, {
      method: 'POST',
      body: new FormData(form),
      headers: { 'Accept': 'application/json' }
    });
    if (res.ok) {
      status.textContent = 'Wiadomość wysłana! Dziękuję.';
      status.style.color = '#39ff14';
      form.reset();
      setTimeout(() => toggleContactForm(), 2500);
    } else {
      status.textContent = 'Błąd wysyłania. Spróbuj ponownie.';
      status.style.color = '#ff4444';
    }
  } catch(err) {
    status.textContent = 'Błąd połączenia.';
    status.style.color = '#ff4444';
  }
}
</script>
</body>
