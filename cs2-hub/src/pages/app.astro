      statusEl.style.cssText='display:block;background:rgba(57,255,20,0.1);border:1px solid rgba(57,255,20,0.3);color:#39ff14;margin-top:12px;padding:10px 14px;border-radius:8px;font-size:13px;text-align:center';
      statusEl.textContent='Portfel jest teraz publiczny';
