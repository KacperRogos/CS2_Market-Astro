// ── HISTORIA ────────────────────────────────────────────────
let historyChart = null, historyRange = 7, historyData = [];

function setHistoryRange(days) {
  historyRange = days;
  [7,30,90].forEach(d => { const btn = document.getElementById('hrange-' + d); if (btn) btn.className = 'filter-btn' + (d === days ? ' active' : ''); });
  renderHistory();
