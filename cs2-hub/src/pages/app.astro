function setCategory(cat) {
  currentCategory = cat;
  document.querySelectorAll('[id^="cat-"]').forEach(b => b.classList.remove('active'));
  const btn = document.getElementById('cat-' + cat); if (btn) btn.classList.add('active');
  renderItems();
