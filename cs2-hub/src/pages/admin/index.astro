---
import Layout from '../../layouts/Layout.astro';
import Icon from '../../components/Icon.astro';
---

<Layout title="Panel admina — CS2 Trading Hub" description="Panel zarządzania danymi." noindex={true}>

<div id="authScreen" class="auth-screen">
  <div class="auth-box">
    <h1>Panel admina</h1>
    <p class="auth-sub">Zaloguj się, żeby zarządzać danymi.</p>
    <form id="loginForm">
      <label>
        Email
        <input class="admin-input" type="email" id="loginEmail" required autocomplete="username" />
      </label>
      <label>
        Hasło
        <input class="admin-input" type="password" id="loginPassword" required autocomplete="current-password" />
      </label>
      <button type="submit" class="btn btn-primary" id="loginBtn">Zaloguj</button>
      <p id="loginError" class="error-text"></p>
    </form>
  </div>
</div>

<div id="adminContent" class="container admin-content" style="display:none">
  <div class="dash-header">
    <h1>Panel admina</h1>
    <div class="dash-header-actions">
      <button id="logoutBtn" class="btn btn-ghost">Wyloguj</button>
    </div>
  </div>

  <div class="admin-cards">
    <a href="/admin/dodaj" class="admin-card">
      <span class="admin-card-icon"><Icon name="plus" size={22} /></span>
      <h3>Dodaj skina</h3>
      <p>Formularz dodawania nowego skina do bazy.</p>
    </a>
    <a href="/admin/skiny" class="admin-card">
      <span class="admin-card-icon"><Icon name="list" size={22} /></span>
      <h3>Istniejące skiny</h3>
      <p>Przeglądaj i usuwaj skiny z bazy.</p>
    </a>
    <a href="/admin/dodaj-skrzynke" class="admin-card">
      <span class="admin-card-icon"><Icon name="box" size={22} /></span>
      <h3>Dodaj skrzynkę</h3>
      <p>Formularz dodawania nowej skrzynki i jej zawartości.</p>
    </a>
    <a href="/admin/skrzynki" class="admin-card">
      <span class="admin-card-icon"><Icon name="archive" size={22} /></span>
      <h3>Istniejące skrzynki</h3>
      <p>Przeglądaj i usuwaj skrzynki z bazy.</p>
    </a>
    <a href="/admin/ikonki" class="admin-card">
      <span class="admin-card-icon"><Icon name="crosshair" size={22} /></span>
      <h3>Ikony przedmiotów</h3>
      <p>Cache obrazków dla portfela — omija zawodny scraping Steam.</p>
    </a>
  </div>

  <section class="panel rebuild-panel">
    <h2>Publikacja zmian</h2>
    <p class="hint-text">
      Strona jest generowana statycznie (SSG) — dodanie/usunięcie skina lub skrzynki
      w panelu <strong>nie pojawi się od razu</strong> na żywej stronie. Kliknij poniżej,
      żeby uruchomić nowy build na Netlify z aktualnymi danymi z bazy (trwa zwykle 1-3 minuty).
    </p>
    <button id="rebuildBtn" class="btn btn-primary btn-icon">
      <Icon name="refresh" size={16} />
      <span>Rebuduj stronę</span>
    </button>
    <p id="rebuildStatus" class="success-text"></p>
  </section>
</div>

<script>
  import { supabase, guardAdminPage } from '../../lib/adminAuth';

  const rebuildBtn = document.getElementById('rebuildBtn');
  const rebuildStatus = document.getElementById('rebuildStatus');
  const rebuildLabel = rebuildBtn?.querySelector('span');

  rebuildBtn?.addEventListener('click', async () => {
    rebuildStatus.textContent = '';
    rebuildStatus.className = 'success-text';
    rebuildBtn.disabled = true;
    if (rebuildLabel) rebuildLabel.textContent = 'Wysyłanie...';

    try {
      const { data: { session } } = await supabase.auth.getSession();
      if (!session) {
        rebuildStatus.textContent = 'Sesja wygasła — zaloguj się ponownie.';
        rebuildStatus.className = 'error-text';
        return;
      }

      const res = await fetch('/api/rebuild', {
        method: 'POST',
        headers: { Authorization: `Bearer ${session.access_token}` },
      });
      const body = await res.json();

      if (!res.ok) {
        rebuildStatus.textContent = 'Błąd: ' + (body.error || res.statusText);
        rebuildStatus.className = 'error-text';
        return;
      }

      rebuildStatus.textContent = 'Rebuild uruchomiony na Netlify — poczekaj 1-3 minuty i odśwież stronę.';
      rebuildStatus.className = 'success-text';
    } catch (err) {
      rebuildStatus.textContent = 'Błąd sieci: ' + err.message;
      rebuildStatus.className = 'error-text';
    } finally {
      rebuildBtn.disabled = false;
      if (rebuildLabel) rebuildLabel.textContent = 'Rebuduj stronę';
    }
  });

  guardAdminPage(() => {});
</script>
</Layout>
