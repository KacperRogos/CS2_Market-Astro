---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Istniejące skiny — Panel admina" description="Lista skinów w bazie." noindex={true}>

<div id="authScreen" class="auth-screen">
  <div class="auth-box">
    <h1>Panel admina</h1>
    <p class="auth-sub">Zaloguj się, żeby zarządzać danymi.</p>
    <form id="loginForm">
      <label>
        Email
        <input class="admin-input" type="email" id="loginEmail" required autocomplete="username" />
      </label>
      <label>
        Hasło
        <input class="admin-input" type="password" id="loginPassword" required autocomplete="current-password" />
      </label>
      <button type="submit" class="btn btn-primary" id="loginBtn">Zaloguj</button>
      <p id="loginError" class="error-text"></p>
    </form>
  </div>
</div>

<div id="adminContent" class="container admin-content" style="display:none">
  <div class="dash-header">
    <h1>Istniejące skiny (<span id="skinCount">0</span>)</h1>
    <div class="dash-header-actions">
      <a href="/admin/dodaj" class="btn btn-primary">➕ Dodaj skina</a>
      <a href="/admin" class="btn btn-ghost">← Panel</a>
      <button id="logoutBtn" class="btn btn-ghost">Wyloguj</button>
    </div>
  </div>
  <p id="dashError" class="error-text"></p>

  <section class="panel">
    <div id="skinList" class="skin-list"></div>
  </section>
</div>

<script>
  import { supabase, guardAdminPage } from '../../lib/adminAuth';

  const dashError = document.getElementById('dashError');
  const skinList = document.getElementById('skinList');
  const skinCount = document.getElementById('skinCount');

  async function loadSkins() {
    dashError.textContent = '';
    const { data, error } = await supabase.from('skins').select('*').order('weapon').order('name');
    if (error) {
      dashError.textContent = 'Nie udało się pobrać skinów: ' + error.message;
      return;
    }
    skinCount.textContent = data.length;
    skinList.innerHTML = data.map(s => `
      <div class="skin-row" data-id="${s.id}">
        <span class="skin-row-name">${s.weapon} | ${s.name}</span>
        <span class="skin-row-meta">${s.category} · ${s.rarity}</span>
        <button class="btn btn-ghost btn-small delete-btn" data-id="${s.id}">Usuń</button>
      </div>
    `).join('') || '<p class="empty-text">Brak skinów w bazie.</p>';

    skinList.querySelectorAll('.delete-btn').forEach(btn => {
      btn.addEventListener('click', () => deleteSkin(btn.getAttribute('data-id')));
    });
  }

  async function deleteSkin(id) {
    if (!confirm('Na pewno usunąć ten skin?')) return;
    dashError.textContent = '';

    // .select() po delete() jest kluczowe: bez tego, jeśli RLS zablokuje operację,
    // Supabase NIE zwraca błędu — po prostu cicho usuwa 0 wierszy. Dzięki .select()
    // widzimy dokładnie ile wierszy faktycznie zniknęło i możemy to zgłosić.
    const { data, error } = await supabase.from('skins').delete().eq('id', id).select('id');

    if (error) {
      dashError.textContent = 'Nie udało się usunąć: ' + error.message;
      return;
    }
    if (!data || data.length === 0) {
      dashError.textContent =
        'Usuwanie nie powiodło się po cichu (0 wierszy) — najprawdopodobniej Twoje konto nie jest w tabeli "admins" w Supabase (RLS blokuje operację). Sprawdź czy uruchomiłeś insert into public.admins z Twoim UID.';
      return;
    }
    await loadSkins();
  }

  guardAdminPage(loadSkins);
</script>
</Layout>
