</ul>
<h2>Praktyczne podejście</h2>
<p>Jeśli okazjonalnie sprzedajesz skiny za niewielkie kwoty, ryzyko jest niskie. Jeśli regularnie handlujesz i zarabiasz znaczące kwoty — warto skonsultować się z księgowym i rozważyć założenie działalności gospodarczej.</p>
<h2>Dokumentacja</h2>
<p>Zawsze zachowuj historię transakcji z platform handlowych. W przypadku kontroli, dokumentacja pokazująca koszty zakupu i ceny sprzedaży pozwoli obliczyć faktyczny dochód (nie przychód).</p>
    `,
  },
};

export function getStaticPaths() {
  const slugs = ["jak-handlowac-skinami-cs2","float-value-przewodnik","najlepsze-skiny-do-inwestowania-2025","czy-warto-otwierac-skrzynki","buff163-vs-steam-market","jak-czytac-wykres-cen-steamu","stickery-na-skinach-wartosc","bezpieczenstwo-handel-skinami","pattern-index-cs2","jak-importowac-ekwipunek-steam","skiny-stattrack-czy-warto","noze-cs2-ranking","trading-up-kontrakty","cs2-major-wplyw-na-ceny","skinport-przewodnik","souvenir-skiny-cs2","portfel-skinow-dywersyfikacja","rekawice-cs2-przewodnik","podatek-od-handlu-skinami"];
  return slugs.map(slug => ({ params: { slug } }));
}

const { slug } = Astro.params;
const article = articles[slug];

if (!article) {
  return Astro.redirect('/poradniki');
}

const schema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": article.title,
  "description": article.description,
  "url": `https://cs2-market.netlify.app/poradniki/${slug}`,
  "datePublished": article.date,
  "inLanguage": "pl",
  "author": { "@type": "Organization", "name": "CS2 Trading Hub" },
  "publisher": { "@type": "Organization", "name": "CS2 Trading Hub", "url": "https://cs2-market.netlify.app" },
};
---

<Layout
  title={`${article.title} | CS2 Trading Hub`}
  description={article.description}
  schema={schema}
>

<div class="container">

  <nav class="breadcrumb" aria-label="Breadcrumb">
    <a href="/">Strona główna</a><span>›</span>
    <a href="/poradniki">Poradniki</a><span>›</span>
    <span>{article.category}</span>
  </nav>

  <div class="article-layout">
    <article class="article-main">

      <div class="article-header">
        <div class="article-meta-top">
          <span class={`article-cat cat-${article.category.toLowerCase().replace(/ą/g,'a').replace(/ę/g,'e').replace(/ś/g,'s')}`}>
            {article.category}
          </span>
          <span class="article-read-time">⏱ {article.readTime} czytania</span>
          <span class="article-date">
            {new Date(article.date).toLocaleDateString('pl-PL', { day: 'numeric', month: 'long', year: 'numeric' })}
          </span>
        </div>
        <h1>{article.title}</h1>
        <p class="article-lead">{article.description}</p>
        <div class="article-tags">
          {article.tags.map(tag => <span class="article-tag">#{tag}</span>)}
        </div>
      </div>

      <div class="article-content" set:html={article.content} />

      <div class="article-footer-nav">
        <a href="/poradniki" class="btn btn-ghost">← Wszystkie poradniki</a>
        <a href="/kalkulator" class="btn btn-primary">Kalkulator skrzynek →</a>
      </div>

    </article>

    <aside class="article-sidebar">
      <div class="sidebar-card">
        <h3>Przydatne narzędzia</h3>
        <a href="/kalkulator" class="sidebar-link">
          <span>🎲</span>
          <div>
            <strong>Kalkulator skrzynek</strong>
            <p>Sprawdź szanse drop rate</p>
          </div>
        </a>
        <a href="/skins" class="sidebar-link">
          <span>🔫</span>
          <div>
            <strong>Baza skinów</strong>
            <p>Opisy i float range</p>
          </div>
        </a>
        <a href="/app" class="sidebar-link">
          <span>💼</span>
          <div>
            <strong>Tracker portfela</strong>
            <p>Śledź wartość kolekcji</p>
          </div>
        </a>
      </div>

      <div class="sidebar-card">
        <h3>Inne poradniki</h3>
        <div class="sidebar-articles">
          <a href="/poradniki/jak-handlowac-skinami-cs2" class="sidebar-article-link">Jak zacząć handlować skinami CS2</a>
          <a href="/poradniki/float-value-przewodnik" class="sidebar-article-link">Float value – kompletny przewodnik</a>
          <a href="/poradniki/czy-warto-otwierac-skrzynki" class="sidebar-article-link">Czy warto otwierać skrzynki?</a>
          <a href="/poradniki/buff163-vs-steam-market" class="sidebar-article-link">Buff163 vs Steam Market</a>
          <a href="/poradniki/bezpieczenstwo-handel-skinami" class="sidebar-article-link">Bezpieczeństwo przy handlu</a>
        </div>
      </div>
    </aside>
  </div>

</div>

</Layout>

<style is:global>
.breadcrumb { display:flex; align-items:center; gap:8px; padding:20px 0 0; font-size:13px; color:var(--text2); flex-wrap:wrap; }
.breadcrumb a { color:var(--text2); text-decoration:none; }
.breadcrumb a:hover { color:var(--accent); }

.article-layout { display:grid; grid-template-columns:1fr 300px; gap:48px; padding:40px 0 80px; align-items:start; }

/* Article main */
.article-header { margin-bottom:40px; padding-bottom:32px; border-bottom:1px solid var(--border); }
.article-meta-top { display:flex; align-items:center; gap:14px; flex-wrap:wrap; margin-bottom:20px; }
.article-cat { font-family:var(--font-mono); font-size:10px; text-transform:uppercase; letter-spacing:1.5px; padding:3px 10px; border-radius:4px; font-weight:600; }
.cat-podstawy      { background:rgba(0,212,255,0.12); color:var(--accent); border:1px solid rgba(0,212,255,0.2); }
.cat-edukacja      { background:rgba(136,71,255,0.12); color:var(--purple); border:1px solid rgba(136,71,255,0.2); }
.cat-inwestowanie  { background:rgba(57,255,20,0.12); color:#39ff14; border:1px solid rgba(57,255,20,0.2); }
.cat-analiza       { background:rgba(228,174,57,0.12); color:var(--gold); border:1px solid rgba(228,174,57,0.2); }
.cat-platformy     { background:rgba(235,75,75,0.12); color:var(--red); border:1px solid rgba(235,75,75,0.2); }
.cat-bezpieczenstwo { background:rgba(76,175,80,0.12); color:#4caf50; border:1px solid rgba(76,175,80,0.2); }
.article-read-time { font-family:var(--font-mono); font-size:11px; color:var(--text2); }
.article-date { font-family:var(--font-mono); font-size:11px; color:var(--text2); opacity:0.6; }

.article-header h1 { font-size:clamp(22px,3.5vw,38px); font-weight:900; line-height:1.25; margin-bottom:16px; }
.article-lead { font-size:17px; color:var(--text2); line-height:1.7; margin-bottom:16px; }
.article-tags { display:flex; gap:8px; flex-wrap:wrap; }
.article-tag { font-family:var(--font-mono); font-size:10px; color:var(--text2); background:var(--bg3); border:1px solid var(--border); border-radius:4px; padding:2px 8px; }

/* Article content */
.article-content { color:var(--text); line-height:1.85; font-size:16px; }
.article-content :global(h2) { font-size:22px; font-weight:700; color:#e8f4f8; margin:36px 0 14px; padding-top:4px; }
.article-content :global(h3) { font-size:18px; font-weight:700; color:#e8f4f8; margin:24px 0 10px; }
.article-content :global(p) { margin-bottom:16px; color:var(--text2); }
.article-content :global(ul) { margin:0 0 20px 20px; color:var(--text2); }
.article-content :global(li) { margin-bottom:8px; line-height:1.7; }
.article-content :global(strong) { color:#e8f4f8; font-weight:700; }
.article-content :global(a) { color:var(--accent); text-decoration:underline; }
.article-content :global(a:hover) { color:#00aadd; }

.article-footer-nav { display:flex; justify-content:space-between; gap:12px; flex-wrap:wrap; margin-top:48px; padding-top:32px; border-top:1px solid var(--border); }

/* Sidebar */
.sidebar-card { background:var(--bg2); border:1px solid var(--border); border-radius:var(--radius); padding:20px; margin-bottom:20px; }
.sidebar-card h3 { font-size:14px; font-weight:700; text-transform:uppercase; letter-spacing:1px; color:var(--text2); margin-bottom:16px; font-family:var(--font-mono); }

.sidebar-link { display:flex; align-items:flex-start; gap:12px; padding:10px 0; border-bottom:1px solid var(--border); text-decoration:none; transition:color 0.2s; }
.sidebar-link:last-child { border-bottom:none; }
.sidebar-link span { font-size:20px; flex-shrink:0; }
.sidebar-link strong { display:block; font-size:14px; color:#e8f4f8; margin-bottom:2px; }
.sidebar-link p { font-size:12px; color:var(--text2); margin:0; }
.sidebar-link:hover strong { color:var(--accent); }

.sidebar-articles { display:flex; flex-direction:column; gap:2px; }
.sidebar-article-link { display:block; font-size:13px; color:var(--text2); text-decoration:none; padding:8px 0; border-bottom:1px solid var(--border); line-height:1.4; transition:color 0.2s; }
.sidebar-article-link:last-child { border-bottom:none; }
.sidebar-article-link:hover { color:var(--accent); }

@media (max-width:900px) {
  .article-layout { grid-template-columns:1fr; }
  .article-sidebar { order:-1; }
}
</style>
